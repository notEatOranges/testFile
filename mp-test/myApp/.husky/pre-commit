#!/usr/bin/env sh
. "$(dirname -- "$0")/_/husky.sh"

# 运行 lint-staged 检查暂存区的文件
npx lint-staged

# 运行完整的代码检查
echo "🔍 运行完整的代码检查..."

# 检查 JavaScript/JSX 文件
echo "📝 检查 JavaScript/JSX 文件..."
npm run lint
if [ $? -ne 0 ]; then
  echo "❌ ESLint 检查失败，请修复错误后重新提交"
  exit 1
fi

# 检查样式文件
echo "🎨 检查样式文件..."
npm run lint:style
if [ $? -ne 0 ]; then
  echo "❌ Stylelint 检查失败，请修复错误后重新提交"
  exit 1
fi

echo "✅ 所有代码检查通过，可以提交"
