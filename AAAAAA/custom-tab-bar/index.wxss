.tab-bar {
  position: fixed; left: 0; right: 0; bottom: 0; z-index: 100;
  display: flex; height: calc(100rpx + env(safe-area-inset-bottom));
  padding-bottom: env(safe-area-inset-bottom); box-sizing: border-box;
  background: #fff; border-top: 1rpx solid #eee;
  transition: transform .22s cubic-bezier(.2,.8,.2,1);
}
/* Skyline 下自定义 tabBar 是独立渲染层，页面内 z-index 盖不住 → 需要遮盖弹层时直接滑出屏幕 */
.tab-bar--hide { transform: translateY(120%); }
.tab-item {
  flex: 1; display: flex; flex-direction: column; align-items: center; justify-content: center;
  gap: 4rpx; color: #9a9a9a;
}
.tab-item.on { color: #ff7aa2; }
.tab-ic { line-height: 1; }
.tab-text { font-size: 22rpx; }
