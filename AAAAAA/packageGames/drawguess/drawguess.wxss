.dg-page { padding-top: 16rpx; padding-bottom: calc(40rpx + env(safe-area-inset-bottom)); }

.dg-top { display: flex; align-items: center; gap: 16rpx; margin-bottom: 20rpx; }
.dg-score { flex: 1; display: flex; align-items: center; justify-content: center; gap: 28rpx; }
.ds-item { display: flex; flex-direction: column; align-items: center; padding: 8rpx 32rpx; border-radius: 18rpx; background: var(--card); box-shadow: 0 6rpx 20rpx var(--card-shadow); }
.ds-item .lbl { font-size: 24rpx; color: var(--text-soft); }
.ds-item .val { font-size: 42rpx; font-weight: 800; color: var(--primary-deep); }
.ds-vs { font-size: 26rpx; color: var(--text-soft); font-weight: 700; }
.dg-rules-btn { width: 64rpx; height: 64rpx; border-radius: 50%; background: var(--card); color: var(--primary); display: flex; align-items: center; justify-content: center; box-shadow: 0 4rpx 16rpx var(--card-shadow); }

.dg-feed { display: flex; flex-direction: column; gap: 18rpx; margin-top: 24rpx; }
.dg-card { padding: 20rpx; }
.dc-img { width: 100%; border-radius: 14rpx; background: #fff; }
.dc-rendering { width: 100%; height: 300rpx; border-radius: 14rpx; background: var(--chip); color: var(--text-soft); display: flex; align-items: center; justify-content: center; font-size: 26rpx; }
.dc-sub { margin: 12rpx 4rpx 8rpx; }
.dc-answer { font-size: 28rpx; color: var(--primary-deep); font-weight: 600; margin-top: 4rpx; }
.dc-answer.mine { color: var(--text-soft); font-weight: 400; }
.dc-guess-row { display: flex; gap: 12rpx; margin-top: 8rpx; }
.dc-input { flex: 1; height: 76rpx; line-height: 76rpx; padding: 0 22rpx; background: var(--chip); border-radius: 38rpx; font-size: 28rpx; color: var(--text); }
.dc-guess-btn { width: 88rpx; height: 76rpx; line-height: 76rpx; text-align: center; border-radius: 38rpx; background: var(--primary); color: #fff; font-size: 28rpx; }
.dc-hint { margin-top: 8rpx; }
.dg-empty { text-align: center; padding: 80rpx 0; font-size: 26rpx; }

/* 反向重绘隐藏画布 */
.hidden-canvas { position: fixed; left: -9999rpx; top: 0; width: 320px; height: 320px; opacity: 0; pointer-events: none; }

/* 画画弹层：近全屏 */
.dg-mask { position: fixed; inset: 0; z-index: 300; background: rgba(0,0,0,.4); opacity: 0; pointer-events: none; transition: opacity .2s; }
.dg-mask.show { opacity: 1; pointer-events: auto; }
.draw-sheet {
  position: fixed; left: 0; right: 0; bottom: 0; top: 0; z-index: 301;
  background: var(--bg-1); padding: calc(env(safe-area-inset-top) + 16rpx) 24rpx calc(env(safe-area-inset-bottom) + 24rpx);
  display: flex; flex-direction: column; transform: translateY(100%); transition: transform .26s cubic-bezier(.2,.8,.2,1);
}
.draw-sheet.show { transform: translateY(0); }
.ds-head { display: flex; align-items: center; gap: 14rpx; margin-bottom: 12rpx; }
.ds-mode { padding: 8rpx 22rpx; border-radius: 24rpx; background: var(--card); color: var(--text-soft); font-size: 26rpx; }
.ds-mode.sel { background: var(--primary); color: #fff; }
.ds-close { margin-left: auto; color: var(--text-soft); padding: 6rpx; }
.ds-word { display: flex; align-items: center; gap: 18rpx; margin-bottom: 14rpx; }
.ds-w { font-size: 44rpx; font-weight: 800; color: var(--primary-deep); }
.ds-reroll { font-size: 26rpx; color: var(--primary); padding: 8rpx 18rpx; background: var(--card); border-radius: 22rpx; }
.ds-custom { flex: 1; height: 72rpx; line-height: 72rpx; padding: 0 22rpx; background: var(--card); border-radius: 16rpx; font-size: 30rpx; color: var(--text); }

.draw-canvas { width: 92vw; height: 92vw; max-height: 56vh; background: #fff; border-radius: 16rpx; box-shadow: 0 8rpx 30rpx var(--card-shadow); align-self: center; }

.ds-tools { display: flex; align-items: center; justify-content: space-between; margin-top: 14rpx; gap: 12rpx; }
.ds-colors { display: flex; align-items: center; gap: 12rpx; }
.ds-color { width: 52rpx; height: 52rpx; border-radius: 50%; border: 3rpx solid #fff; box-shadow: 0 2rpx 8rpx rgba(0,0,0,.18); }
.ds-color.sel { box-shadow: 0 0 0 3rpx var(--card), 0 0 0 7rpx var(--primary); }
.ds-tool { width: 56rpx; height: 52rpx; border-radius: 14rpx; background: var(--card); color: var(--text-soft); display: flex; align-items: center; justify-content: center; }
.ds-tool.sel { color: var(--primary-deep); box-shadow: 0 0 0 3rpx var(--primary); }
.ds-widths { display: flex; align-items: center; gap: 10rpx; }
.ds-width { width: 52rpx; height: 52rpx; border-radius: 50%; background: var(--card); display: flex; align-items: center; justify-content: center; }
.ds-width.sel { box-shadow: 0 0 0 3rpx var(--primary); }
.dw-dot { border-radius: 50%; background: var(--text-soft); }

.ds-hue { display: flex; align-items: center; gap: 12rpx; margin-top: 12rpx; }
.ds-slider { flex: 1; margin: 0; }
.ds-curno { width: 40rpx; height: 40rpx; border-radius: 50%; border: 3rpx solid var(--card); box-shadow: 0 2rpx 8rpx rgba(0,0,0,.18); }

.ds-actions { display: flex; gap: 16rpx; margin-top: 16rpx; }
.ds-actions .love-btn { flex: 1; }
