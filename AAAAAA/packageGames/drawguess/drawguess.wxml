<view class="theme-{{theme}} love-page dg-page">

  <!-- 分数 -->
  <view class="dg-score">
    <view class="ds-item"><text class="lbl">{{myName}}</text><text class="val">{{myScore}}</text></view>
    <view class="ds-vs">VS</view>
    <view class="ds-item"><text class="lbl">{{peerName}}</text><text class="val">{{peerScore}}</text></view>
  </view>

  <!-- 空闲：开始 -->
  <block wx:if="{{mode === 'idle'}}">
    <view class="dg-center">
      <view class="dg-big-ic"><t-icon name="edit-1" size="72rpx" /></view>
      <view class="dg-title">你画我猜</view>
      <view class="muted small">一个人画，另一个人猜，猜对得分，轮流来</view>
      <t-button theme="primary" class="love-btn" loading="{{starting}}" bind:tap="startAsDrawer" icon="edit-1">我来出题画画</t-button>
    </view>
  </block>

  <!-- 我画 -->
  <block wx:elif="{{mode === 'drawing'}}">
    <view class="word-bar">
      <text class="wb-tip">你抽到的词</text>
      <text class="wb-word">{{word}}</text>
      <text class="wb-hint muted small">提示给 ta：{{hint}}</text>
    </view>
    <canvas type="2d" id="drawCanvas" class="draw-canvas"
            bindtouchstart="drawStart" bindtouchmove="drawMove" bindtouchend="drawEnd"></canvas>
    <view class="color-row">
      <view wx:for="{{colors}}" wx:key="*this" class="color-dot {{color === item ? 'sel' : ''}}" style="background:{{item}}" data-c="{{item}}" bindtap="pickColor"></view>
      <view class="clear-btn" bindtap="clearCanvas"><t-icon name="delete" size="32rpx" /><text>清空</text></view>
    </view>
    <view class="dg-actions">
      <t-button theme="default" class="love-btn ghost" bind:tap="giveUp">公布答案</t-button>
      <t-button theme="primary" class="love-btn" loading="{{submitting}}" bind:tap="submitDrawing">画好了，交给大家猜</t-button>
    </view>
  </block>

  <!-- 等 ta 画 -->
  <block wx:elif="{{mode === 'wait'}}">
    <view class="dg-center">
      <view class="dg-big-ic"><t-icon name="edit-1" size="72rpx" /></view>
      <view class="dg-title">{{peerName}} 正在画</view>
      <view class="muted small">提示：{{hint}}　等 ta 画完你来猜</view>
    </view>
  </block>

  <!-- 我已交，等 ta 猜 -->
  <block wx:elif="{{mode === 'submitted'}}">
    <view class="dg-center">
      <view class="dg-big-ic"><t-icon name="user" size="72rpx" /></view>
      <view class="dg-title">等 {{peerName}} 来猜</view>
      <view class="muted small">答案是「{{word}}」，等 ta 猜对就得分啦</view>
    </view>
  </block>

  <!-- 我猜 -->
  <block wx:elif="{{mode === 'guessing'}}">
    <view class="word-bar"><text class="wb-tip">ta 画的（提示：{{hint}}）</text></view>
    <image wx:if="{{drawing}}" class="guess-img" src="{{drawing}}" mode="widthFix" />
    <view wx:else class="muted small">画手还没提交</view>
    <input class="dg-input" placeholder="你觉得画的是什么？" value="{{guess}}" bindinput="onGuess" bindconfirm="submitGuess" />
    <t-button theme="primary" block class="love-btn" bind:tap="submitGuess">提交猜测</t-button>
  </block>

  <!-- 揭晓 -->
  <block wx:elif="{{mode === 'revealed'}}">
    <view class="dg-center">
      <image wx:if="{{drawing}}" class="reveal-img" src="{{drawing}}" mode="widthFix" />
      <view class="dg-title">答案是「{{showWord}}」</view>
      <view class="muted">{{winnerName}} 得分</view>
      <t-button theme="primary" class="love-btn" bind:tap="nextRound" icon="refresh">下一局（换人画）</t-button>
    </view>
  </block>
</view>
