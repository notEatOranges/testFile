<view class="theme-{{theme}} love-page dg-page">

  <view class="dg-top">
    <view class="dg-score">
      <view class="ds-item"><text class="lbl">{{myName}}</text><text class="val">{{myScore}}</text></view>
      <view class="ds-vs">VS</view>
      <view class="ds-item"><text class="lbl">{{peerName}}</text><text class="val">{{peerScore}}</text></view>
    </view>
    <view class="dg-rules-btn" bindtap="openRules"><t-icon name="info-circle" size="36rpx" /></view>
  </view>

  <t-button theme="primary" block class="love-btn" bind:tap="openDraw" icon="edit-1">我来画一幅</t-button>

  <!-- 画作信息流（双向：都能画、都能猜） -->
  <view class="dg-feed">
    <block wx:if="{{items.length}}">
      <view wx:for="{{items}}" wx:key="id" class="love-card dg-card">
        <image wx:if="{{item.src}}" class="dc-img" src="{{item.src}}" mode="widthFix" />
        <view wx:else class="dc-rendering">渲染中…</view>
        <view class="dc-sub muted small">由 {{item.creatorName}} 画</view>
        <block wx:if="{{item.winner}}">
          <view class="dc-answer">答案：{{item.word}} · {{item.winnerName}} 猜中</view>
        </block>
        <block wx:elif="{{item.byMe}}">
          <view class="dc-answer mine">你画的：{{item.word}}（等 ta 猜）</view>
        </block>
        <block wx:else>
          <view class="dc-guess-row">
            <input class="dc-input" placeholder="这幅画的是什么？" value="{{item.g}}" data-idx="{{index}}" bindinput="onCardGuess" />
            <view class="dc-guess-btn" data-idx="{{index}}" bindtap="submitGuess">猜</view>
          </view>
          <view wx:if="{{item.hint}}" class="dc-hint muted small">提示：{{item.hint}}</view>
        </block>
      </view>
    </block>
    <view wx:else class="dg-empty muted">还没有画作，点上面画一幅发给 ta 猜吧</view>
  </view>

  <!-- 反向重绘用的隐藏画布 -->
  <canvas type="2d" id="renderer" class="hidden-canvas"></canvas>

  <!-- 画画弹层（近全屏） -->
  <view class="dg-mask {{drawOpen ? 'show' : ''}}"></view>
  <view class="draw-sheet {{drawOpen ? 'show' : ''}}" catchtap="noop">
    <view class="ds-head">
      <view class="ds-mode {{wordMode === 'random' ? 'sel' : ''}}" data-m="random" bindtap="switchWordMode">随机词</view>
      <view class="ds-mode {{wordMode === 'custom' ? 'sel' : ''}}" data-m="custom" bindtap="switchWordMode">自定义</view>
      <view class="ds-close" bindtap="closeDraw"><t-icon name="close" size="36rpx" /></view>
    </view>
    <view class="ds-word">
      <block wx:if="{{wordMode === 'random'}}">
        <text class="ds-w">{{word}}</text>
        <text class="ds-reroll" bindtap="rerollWord">换一词</text>
      </block>
      <block wx:else>
        <input class="ds-custom" placeholder="输入要画的词" value="{{customWord}}" bindinput="onCustomWord" maxlength="8" />
      </block>
    </view>

    <canvas type="2d" id="drawCanvas" class="draw-canvas"
            bindtouchstart="drawStart" bindtouchmove="drawMove" bindtouchend="drawEnd"></canvas>

    <view class="ds-tools">
      <view class="ds-colors">
        <view wx:for="{{quick}}" wx:key="*this" class="ds-color {{color === item && tool === 'pen' ? 'sel' : ''}}" style="background:{{item}}" data-c="{{item}}" bindtap="pickColor"></view>
        <view class="ds-tool {{tool === 'eraser' ? 'sel' : ''}}" bindtap="pickTool" data-t="eraser"><t-icon name="edit-2" size="32rpx" /></view>
      </view>
      <view class="ds-widths">
        <view wx:for="{{widths}}" wx:key="*this" class="ds-width {{width === item ? 'sel' : ''}}" data-w="{{item}}" bindtap="pickWidth">
          <view class="dw-dot" style="width:{{item + 6}}rpx;height:{{item + 6}}rpx"></view>
        </view>
      </view>
    </view>
    <view class="ds-hue">
      <text class="muted small">色相</text>
      <slider class="ds-slider" min="0" max="360" value="{{hue}}" bindchanging="onHue" bindchange="onHue" activeColor="{{color}}" />
      <view class="ds-curno" style="background:{{color}}"></view>
    </view>

    <view class="ds-actions">
      <t-button theme="default" class="love-btn" bind:tap="clearDraw" icon="delete">清空</t-button>
      <t-button theme="primary" class="love-btn" loading="{{submitting}}" bind:tap="submitDraw">画好，发给大家猜</t-button>
    </view>
  </view>

  <game-rules game-key="drawguess" open="{{rulesOpen}}" bind:close="closeRules" />
</view>
