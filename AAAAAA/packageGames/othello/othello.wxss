.ot-page { display: flex; flex-direction: column; align-items: center; padding-top: 24rpx; }

.ot-bar { display: flex; align-items: center; gap: 24rpx; margin-bottom: 18rpx; }
.seat { display: flex; align-items: center; gap: 12rpx; min-width: 200rpx; padding: 14rpx 22rpx; border-radius: 18rpx; background: var(--card); box-shadow: 0 6rpx 20rpx var(--card-shadow); }
.stone-dot { width: 40rpx; height: 40rpx; border-radius: 50%; flex-shrink: 0; box-shadow: 0 2rpx 6rpx rgba(0,0,0,.2); }
.stone-dot.red { background: #e85a86; }
.stone-dot.blue { background: #3a86ff; }
.seat-name { font-size: 26rpx; font-weight: 600; color: var(--text); }
.seat-score { font-size: 40rpx; font-weight: 800; color: var(--primary-deep); margin-left: auto; }
.vs { font-size: 26rpx; color: var(--text-soft); font-weight: 700; }

.ot-result { font-size: 36rpx; font-weight: 800; color: var(--primary-deep); margin-bottom: 8rpx; }
.ot-tip { margin-bottom: 8rpx; }
.ot-pending { display: flex; align-items: center; gap: 16rpx; margin-bottom: 10rpx; padding: 12rpx 22rpx; border-radius: 18rpx; background: var(--card); box-shadow: 0 4rpx 16rpx var(--card-shadow); font-size: 25rpx; color: var(--primary-deep); }
.ot-link { margin-left: auto; color: var(--text-soft); padding: 4rpx 10rpx; }

.board-wrap { position: relative; }
.board { width: 94vw; height: 94vw; max-width: 760rpx; max-height: 760rpx; border-radius: 16rpx; box-shadow: 0 8rpx 30rpx var(--card-shadow); }
.board-empty { position: absolute; left: 0; top: 0; right: 0; bottom: 0; border-radius: 16rpx; background: rgba(78,163,107,0.94); display: flex; flex-direction: column; align-items: center; justify-content: center; gap: 14rpx; }
.be-text { font-size: 30rpx; color: #fff; }
.be-btn { padding: 16rpx 48rpx; border-radius: 36rpx; background: var(--primary); color: #fff; font-size: 28rpx; }

.ot-actions { display: flex; gap: 16rpx; margin-top: 28rpx; flex-wrap: wrap; justify-content: center; }
