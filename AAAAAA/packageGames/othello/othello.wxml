<view class="theme-{{theme}} love-page ot-page">

  <view class="ot-bar">
    <view class="seat">
      <view class="stone-dot {{mySeat}}"></view>
      <view class="seat-name">{{myName}}</view>
      <view class="seat-score">{{myScore}}</view>
    </view>
    <view class="vs">VS</view>
    <view class="seat">
      <view class="stone-dot {{mySeat === 'red' ? 'blue' : 'red'}}"></view>
      <view class="seat-name">{{peerName}}</view>
      <view class="seat-score">{{peerScore}}</view>
    </view>
  </view>

  <view wx:if="{{winner}}" class="ot-result">{{winnerText}}</view>
  <view wx:elif="{{started}}" class="ot-tip muted small">{{turnSeat === mySeat ? '该你落子（白点为可走位置）' : '等 ' + peerName + ' 落子'}}</view>

  <view wx:if="{{requestPending}}" class="ot-pending">
    <text>已请求重新开局，等 {{peerName}} 同意…</text>
    <text class="ot-link" bindtap="cancelReq">取消</text>
  </view>

  <view class="board-wrap">
    <canvas wx:if="{{!rulesOpen}}" type="2d" id="board" class="board" bindtouchend="onBoardTap"></canvas>
    <view wx:if="{{!started}}" class="board-empty">
      <view class="be-text">还没开局</view>
      <view class="be-btn" bindtap="startMatch">开始对局</view>
      <view class="muted small">夹住对方棋子使其翻转，终局子多者胜</view>
    </view>
  </view>

  <view class="ot-actions">
    <t-button theme="default" size="small" bind:tap="openRules" icon="info-circle">玩法</t-button>
    <t-button wx:if="{{started}}" theme="default" size="small" bind:tap="resign">认输</t-button>
    <t-button theme="primary" size="small" bind:tap="requestRestart">{{winner ? '再来一局' : (started ? '重新开局' : '开始对局')}}</t-button>
  </view>

  <game-rules game-key="othello" open="{{rulesOpen}}" bind:close="closeRules" />
</view>
