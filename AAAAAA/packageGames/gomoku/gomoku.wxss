.go-page { display: flex; flex-direction: column; align-items: center; padding-top: 24rpx; }

.go-bar { display: flex; align-items: center; gap: 24rpx; margin-bottom: 18rpx; }
.seat { display: flex; flex-direction: column; align-items: center; gap: 2rpx; min-width: 180rpx; padding: 12rpx 20rpx; border-radius: 18rpx; background: var(--card); box-shadow: 0 6rpx 20rpx var(--card-shadow); }
.seat-name { font-size: 28rpx; font-weight: 600; color: var(--text); }
.vs { font-size: 26rpx; color: var(--text-soft); font-weight: 700; }
.stone-dot { width: 40rpx; height: 40rpx; border-radius: 50%; margin-bottom: 4rpx; box-shadow: 0 2rpx 6rpx rgba(0,0,0,.2); }
.stone-dot.red { background: #e85a86; }
.stone-dot.blue { background: #3a86ff; }

.go-result { font-size: 36rpx; font-weight: 800; color: var(--primary-deep); margin-bottom: 8rpx; }
.go-tip { margin-bottom: 8rpx; }
.go-pending { display: flex; align-items: center; gap: 16rpx; margin-bottom: 10rpx; padding: 12rpx 22rpx; border-radius: 18rpx; background: var(--card); box-shadow: 0 4rpx 16rpx var(--card-shadow); font-size: 25rpx; color: var(--primary-deep); }
.go-link { margin-left: auto; color: var(--text-soft); padding: 4rpx 10rpx; }

.board-wrap { position: relative; }
.board { width: 94vw; height: 94vw; max-width: 760rpx; max-height: 760rpx; border-radius: 16rpx; box-shadow: 0 8rpx 30rpx var(--card-shadow); }
.board-empty {
  position: absolute; left: 0; top: 0; right: 0; bottom: 0; border-radius: 16rpx;
  background: rgba(246,234,208,0.92); display: flex; flex-direction: column; align-items: center; justify-content: center; gap: 14rpx;
}
.be-text { font-size: 30rpx; color: #8a6b4a; }
.be-btn { padding: 16rpx 48rpx; border-radius: 36rpx; background: var(--primary); color: #fff; font-size: 28rpx; }

.go-actions { display: flex; gap: 18rpx; margin-top: 28rpx; }
