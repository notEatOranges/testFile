/* 禁止滚动：100vh 固定，按钮固定底部 */
.mp-page { height: 100vh; overflow: hidden; display: flex; flex-direction: column; align-items: center; padding: 16rpx 0 calc(184rpx + env(safe-area-inset-bottom)); box-sizing: border-box; }
.mp-board-wrap { position: relative; display: flex; align-items: center; justify-content: center; width: 100%; }
.mp-board { position: relative; width: min(94vw, calc(100vh - 644rpx)); height: min(94vw, calc(100vh - 644rpx)); border-radius: 16rpx; box-shadow: 0 8rpx 30rpx var(--card-shadow); display: grid; grid-template-columns: repeat(8, 1fr); grid-template-rows: repeat(8, 1fr); background: #fff8ec; overflow: hidden; }

.mp-empty { position: absolute; inset: 0; border-radius: 16rpx; background: rgba(243,233,210,.95); display: flex; flex-direction: column; align-items: center; justify-content: center; gap: 14rpx; }
.mp-title { font-size: 52rpx; font-weight: 800; color: #b58a5a; }
.mp-start { padding: 16rpx 56rpx; border-radius: 36rpx; background: var(--primary); color: #fff; font-size: 30rpx; }
.mp-over-mask { position: absolute; inset: 0; border-radius: 16rpx; background: rgba(0,0,0,.45); display: flex; flex-direction: column; align-items: center; justify-content: center; gap: 20rpx; }
.mp-over-text { color: #fff; font-size: 44rpx; font-weight: 800; }

/* 双方金币 */
.mp-pair { display: flex; gap: 18rpx; width: 92vw; max-width: 620rpx; margin: 10rpx 0 4rpx; }
.mp-p { flex: 1; display: flex; align-items: center; justify-content: space-between; padding: 10rpx 22rpx; border-radius: 16rpx; background: var(--card); box-shadow: 0 4rpx 14rpx var(--card-shadow); }
.mp-p.me { border-left: 6rpx solid #ff5a5f; }
.mp-n { font-size: 24rpx; font-weight: 600; }
.mp-cash { font-size: 34rpx; font-weight: 800; color: var(--primary-deep); }

.mp-info { width: 92vw; max-width: 620rpx; text-align: center; min-height: 32rpx; }

/* 全部对局记录(主页面内滚动) */
.mp-log-box { width: 92vw; max-width: 620rpx; flex: 1 1 0; min-height: 120rpx; margin: 6rpx 0; box-sizing: border-box; }
.ml-item { font-size: 24rpx; color: var(--text-soft); line-height: 1.7; opacity: .6; padding: 2rpx 0; }
.ml-item.new { opacity: 1; color: var(--primary-deep); font-weight: 600; }
.log-empty { text-align: center; padding: 30rpx 0; }
.mp-result { font-size: 30rpx; font-weight: 800; color: var(--primary-deep); }
.mp-turn { font-size: 24rpx; color: var(--text-soft); }
.mp-pending { font-size: 22rpx; color: var(--primary-deep); }
.mp-link { color: var(--text-soft); padding: 0 6rpx; }

/* 固定底部 tab 栏 + 安全区 */
.mp-tabbar { position: fixed; left: 0; right: 0; bottom: 0; padding: 12rpx 24rpx calc(12rpx + env(safe-area-inset-bottom)); background: var(--bg-1); z-index: 10; display: flex; flex-direction: column; gap: 10rpx; box-sizing: border-box; box-shadow: 0 -4rpx 16rpx var(--card-shadow); }
.mp-tabbar-row { display: flex; gap: 12rpx; }
.mp-tabbar-row .t-button { flex: 1; }

/* 银行/资产面板 */
.bank-sheet { position: fixed; left: 0; right: 0; bottom: 0; z-index: 301; background: var(--card); border-radius: 28rpx 28rpx 0 0; padding: 24rpx 32rpx calc(36rpx + env(safe-area-inset-bottom)); transform: translateY(110%); transition: transform .26s cubic-bezier(.2,.8,.2,1); box-shadow: 0 -8rpx 32rpx var(--card-shadow); max-height: 80vh; display: flex; flex-direction: column; }
.bank-sheet.show { transform: translateY(0); }
.bk-sum { font-size: 28rpx; color: var(--primary-deep); font-weight: 600; margin: 8rpx 0 16rpx; }
.bk-label { font-size: 24rpx; color: var(--text-soft); margin: 14rpx 0 10rpx; }
.bk-btns { display: flex; flex-wrap: wrap; gap: 12rpx; }
.bk-btn { padding: 12rpx 22rpx; border-radius: 28rpx; background: var(--chip); color: var(--primary-deep); font-size: 26rpx; }
.bk-btn.sm { padding: 8rpx 16rpx; font-size: 24rpx; }
.bk-props { max-height: 320rpx; }
.bk-prop { display: flex; align-items: center; justify-content: space-between; gap: 12rpx; padding: 12rpx 0; border-bottom: 1rpx solid var(--border); }
.bp-name { font-size: 26rpx; color: var(--text); }
.bp-acts { display: flex; gap: 10rpx; }

/* 模式选择按钮 + 模式徽标 + 抵押状态 */
.mp-mode-pick { display: flex; gap: 18rpx; }
.mp-start.casual { background: #00b8d4; }
.mp-mode-tag { display: inline-flex; align-items: center; gap: 6rpx; padding: 2rpx 14rpx; border-radius: 20rpx; font-size: 22rpx; color: #fff; vertical-align: middle; margin-right: 12rpx; }
.mp-mode-tag.classic { background: #ff5a5f; }
.mp-mode-tag.casual { background: #00b8d4; }
.mp-mode-mini { margin-left: 12rpx; padding: 2rpx 14rpx; border-radius: 14rpx; font-size: 22rpx; color: #fff; font-weight: 600; }
.mp-mode-mini.classic { background: #ff5a5f; }
.mp-mode-mini.casual { background: #00b8d4; }
.bk-prop.is-mort { opacity: .62; }
.bp-mort-tag { margin-left: 10rpx; color: #b58a5a; font-size: 22rpx; display: inline-flex; align-items: center; gap: 2rpx; }

/* —— DOM 棋盘：8×8 格 + 中心 + 棋子 + 骰子 + 抽牌 + 特效 + 胜利 —— */
.mp-cell { position: relative; border: 1rpx solid #e3d3ad; background: #f7edda; overflow: hidden; display: flex; flex-direction: column; align-items: center; justify-content: flex-start; padding: 4rpx 2rpx; box-sizing: border-box; }
.mp-cell.type-start { background: #d8efd9; }
.mp-cell.type-card { background: #fbe9b8; }
.mp-cell.type-tax { background: #f6c5cf; }
.mp-cell.type-jail { background: #d8c4ad; }
.mp-cell.type-bonus { background: #c5dcf3; }
.mp-cell.type-freepark { background: #c5ecd9; }
.mp-cell-price { font-size: 18rpx; font-weight: 800; line-height: 1; align-self: flex-start; margin-left: 2rpx; }
.mp-cell-name { font-size: 18rpx; color: #5a4030; text-align: center; line-height: 1.15; margin-top: 2rpx; word-break: break-all; }
.mp-cell-icon { line-height: 1; margin: 2rpx 0; color: #6b4a2a; }
.mp-cell-build { position: absolute; bottom: 11rpx; left: 0; right: 0; display: flex; align-items: center; justify-content: center; gap: 1rpx; color: #2e7d32; }
.mp-cell-fullset { position: absolute; top: 3rpx; right: 3rpx; width: 12rpx; height: 12rpx; border-radius: 50%; background: #ffd23f; }
.mp-cell-owner { position: absolute; left: 0; right: 0; bottom: 0; height: 8rpx; }

/* 中心 6×6：跨 grid 中间，放骰子+提示 */
.mp-center { grid-column: 2 / 8; grid-row: 2 / 8; display: flex; flex-direction: column; align-items: center; justify-content: center; gap: 14rpx; }
.mp-dice { width: 110rpx; height: 110rpx; border-radius: 22rpx; background: linear-gradient(180deg, #fff, #ffd6e2); border: 3rpx solid #e85a86; display: flex; align-items: center; justify-content: center; font-size: 64rpx; font-weight: 800; color: #e85a86; box-shadow: 4rpx 8rpx 0 rgba(0,0,0,.12); }
.mp-dice-hint { font-size: 30rpx; font-weight: 800; color: #e85a86; }
.mp-center-hint { font-size: 24rpx; color: var(--text-soft); }

/* 棋子：绝对定位，clip-path 画心/星 */
.mp-token { position: absolute; width: 32rpx; height: 32rpx; transform: translate(-50%, -60%); box-shadow: 0 4rpx 8rpx rgba(0,0,0,.3); border: 3rpx solid #fff; pointer-events: none; z-index: 3; border-radius: 50%; display: flex; align-items: center; justify-content: center; color: #fff; font-weight: 800; }
.mp-token.heart::after { content: '♥'; font-size: 22rpx; line-height: 1; }
.mp-token.star::after { content: '★'; font-size: 18rpx; line-height: 1; }

/* 抽牌浮层(9.9a 最简，翻面 9.9e 加) */
.mp-card-layer { position: absolute; inset: 0; display: flex; align-items: center; justify-content: center; z-index: 8; pointer-events: none; }
.mp-card-reveal { width: 260rpx; min-height: 320rpx; padding: 24rpx 18rpx; border-radius: 20rpx; border: 3rpx solid #fff; display: flex; flex-direction: column; align-items: center; justify-content: center; gap: 14rpx; color: #fff; box-shadow: 0 8rpx 24rpx rgba(0,0,0,.2); }
.mp-card-reveal.good { background: #2ec24e; }
.mp-card-reveal.bad { background: #e85a86; }
.mp-card-title { font-size: 38rpx; font-weight: 800; }
.mp-card-text { font-size: 26rpx; text-align: center; line-height: 1.4; }
.mp-card-shuffle { display: flex; flex-direction: column; align-items: center; gap: 18rpx; }
.mp-card-back { width: 160rpx; height: 220rpx; border-radius: 14rpx; background: #e85a86; color: rgba(255,255,255,.5); font-size: 80rpx; font-weight: 800; display: flex; align-items: center; justify-content: center; border: 2rpx solid #fff; animation: mpCardShake .6s ease-in-out infinite; }
.mp-card-shuffle-hint { font-size: 24rpx; color: #8a6b78; }
@keyframes mpCardShake { 0%,100% { transform: rotate(-6deg) translateX(-6rpx); } 50% { transform: rotate(6deg) translateX(6rpx); } }
.mp-card-face { display: flex; flex-direction: column; align-items: center; gap: 14rpx; }

/* 事件特效横幅 */
.mp-fx { position: absolute; top: 50%; left: 50%; transform: translate(-50%, -50%); padding: 18rpx 40rpx; border-radius: 14rpx; color: #fff; font-weight: 800; font-size: 30rpx; z-index: 9; pointer-events: none; max-width: 80%; text-align: center; box-shadow: 0 6rpx 18rpx rgba(0,0,0,.2); }
.mp-fx.good { background: #2ec24e; }
.mp-fx.bad { background: #e85a86; }

/* 胜利遮罩(复用 .mp-over-mask/.mp-over-text) */
.mp-over-sub { color: rgba(255,255,255,.7); font-size: 26rpx; margin-top: 20rpx; }

/* 图标主题：emoji 字体 / 本地图片 */
.mp-emoji { font-family: "Apple Color Emoji", "Segoe UI Emoji", "Noto Color Emoji", sans-serif; font-size: 34rpx; line-height: 1; }
.mp-emoji.sm { font-size: 24rpx; }
.mp-emoji.xs { font-size: 20rpx; }
.mp-img-icon { width: 36rpx; height: 36rpx; }
.mp-img-icon.sm { width: 26rpx; height: 26rpx; }
.mp-img-icon.xs { width: 20rpx; height: 20rpx; }
.mp-theme-btn { display: inline-flex; align-items: center; gap: 6rpx; padding: 2rpx 14rpx; border-radius: 20rpx; background: var(--chip); color: var(--primary-deep); font-size: 22rpx; vertical-align: middle; margin-right: 12rpx; }
