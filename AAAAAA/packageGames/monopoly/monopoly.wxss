/* 禁止滚动：100vh 固定，按钮固定底部 */
.mp-page { height: 100vh; overflow: hidden; display: flex; flex-direction: column; align-items: center; padding: 16rpx 0 calc(140rpx + env(safe-area-inset-bottom)); box-sizing: border-box; }
.mp-board-wrap { flex: 1; min-height: 0; display: flex; align-items: center; justify-content: center; width: 100%; }
.mp-board { width: min(94vw, calc((100vh - 340rpx) * 0.8)); height: min(calc(94vw * 1.25), calc(100vh - 340rpx)); border-radius: 16rpx; box-shadow: 0 8rpx 30rpx var(--card-shadow); }

.mp-empty { position: absolute; inset: 0; border-radius: 16rpx; background: rgba(243,233,210,.95); display: flex; flex-direction: column; align-items: center; justify-content: center; gap: 14rpx; }
.mp-title { font-size: 52rpx; font-weight: 800; color: #b58a5a; }
.mp-start { padding: 16rpx 56rpx; border-radius: 36rpx; background: var(--primary); color: #fff; font-size: 30rpx; }
.mp-over-mask { position: absolute; inset: 0; border-radius: 16rpx; background: rgba(0,0,0,.45); display: flex; align-items: center; justify-content: center; }
.mp-over-text { color: #fff; font-size: 44rpx; font-weight: 800; }

/* 双方金币 */
.mp-pair { display: flex; gap: 18rpx; width: 92vw; max-width: 620rpx; margin: 10rpx 0 4rpx; }
.mp-p { flex: 1; display: flex; align-items: center; justify-content: space-between; padding: 10rpx 22rpx; border-radius: 16rpx; background: var(--card); box-shadow: 0 4rpx 14rpx var(--card-shadow); }
.mp-p.me { border-left: 6rpx solid #ff5a5f; }
.mp-n { font-size: 24rpx; font-weight: 600; }
.mp-cash { font-size: 34rpx; font-weight: 800; color: var(--primary-deep); }

.mp-info { width: 92vw; max-width: 620rpx; text-align: center; min-height: 36rpx; }
.mp-result { font-size: 30rpx; font-weight: 800; color: var(--primary-deep); }
.mp-turn { font-size: 24rpx; color: var(--text-soft); }
.mp-pending { font-size: 22rpx; color: var(--primary-deep); }
.mp-link { color: var(--text-soft); padding: 0 6rpx; }

/* 固定底部 tab 栏 + 安全区 */
.mp-tabbar { position: fixed; left: 0; right: 0; bottom: 0; padding: 12rpx 24rpx calc(12rpx + env(safe-area-inset-bottom)); background: var(--bg-1); z-index: 10; display: flex; flex-direction: column; gap: 10rpx; box-sizing: border-box; box-shadow: 0 -4rpx 16rpx var(--card-shadow); }
.mp-tabbar-row { display: flex; gap: 12rpx; }
.mp-tabbar-row .t-button { flex: 1; }

/* 银行/资产面板 */
.bank-sheet { position: fixed; left: 0; right: 0; bottom: 0; z-index: 301; background: var(--card); border-radius: 28rpx 28rpx 0 0; padding: 24rpx 32rpx calc(36rpx + env(safe-area-inset-bottom)); transform: translateY(110%); transition: transform .26s cubic-bezier(.2,.8,.2,1); box-shadow: 0 -8rpx 32rpx var(--card-shadow); max-height: 80vh; display: flex; flex-direction: column; }
.bank-sheet.show { transform: translateY(0); }
.bk-sum { font-size: 28rpx; color: var(--primary-deep); font-weight: 600; margin: 8rpx 0 16rpx; }
.bk-label { font-size: 24rpx; color: var(--text-soft); margin: 14rpx 0 10rpx; }
.bk-btns { display: flex; flex-wrap: wrap; gap: 12rpx; }
.bk-btn { padding: 12rpx 22rpx; border-radius: 28rpx; background: var(--chip); color: var(--primary-deep); font-size: 26rpx; }
.bk-btn.sm { padding: 8rpx 16rpx; font-size: 24rpx; }
.bk-props { max-height: 320rpx; }
.bk-prop { display: flex; align-items: center; justify-content: space-between; gap: 12rpx; padding: 12rpx 0; border-bottom: 1rpx solid var(--border); }
.bp-name { font-size: 26rpx; color: var(--text); }
.bp-acts { display: flex; gap: 10rpx; }

/* 抽牌 canvas 动画相关样式已移至 JS(canvas 绘制) */
