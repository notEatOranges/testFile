<view class="theme-{{theme}} love-page mp-page">

  <view class="mp-board-wrap">
    <view wx:if="{{started && !rulesOpen}}" class="mp-board">
      <!-- 28 格外圈 -->
      <view wx:for="{{grid}}" wx:key="idx" class="mp-cell {{item.cls}}" style="grid-column:{{item.col}};grid-row:{{item.row}};">
        <view wx:if="{{item.isFullSet}}" class="mp-cell-fullset" style="background:{{item.groupColor}};"></view>
        <view wx:if="{{item.mortgaged}}" class="mp-mort-stamp" style="border-color:{{item.ownerColor}};color:{{item.ownerColor}}">抵押</view>
        <block wx:if="{{item.type === 'property'}}">
          <view class="mp-cell-top">
            <text class="mp-cell-price" style="color:{{item.groupColor}};">${{item.price}}</text>
            <view wx:if="{{item.icon}}" class="mp-cell-icon-mini">
              <t-icon wx:if="{{iconTheme === 'tdesign'}}" name="{{item.icon.t}}" size="22rpx" />
              <text wx:elif="{{iconTheme === 'emoji'}}" class="mp-emoji xs">{{item.icon.e}}</text>
              <image wx:else class="mp-img-icon xs" src="/packageGames/monopoly/assets/monopoly-icons/{{item.icon.i}}.png" />
            </view>
          </view>
          <view class="mp-cell-build">
            <block wx:if="{{item.level === 3}}">
              <t-icon wx:if="{{iconTheme === 'tdesign'}}" name="{{item.hotelIcon.t}}" size="22rpx" />
              <text wx:elif="{{iconTheme === 'emoji'}}" class="mp-emoji xs">{{item.hotelIcon.e}}</text>
              <image wx:else class="mp-img-icon xs" src="/packageGames/monopoly/assets/monopoly-icons/{{item.hotelIcon.i}}.png" />
            </block>
            <block wx:elif="{{item.level}}">
              <block wx:for="{{item.levelArr}}" wx:for-item="s" wx:key="index">
                <t-icon wx:if="{{iconTheme === 'tdesign'}}" name="{{item.houseIcon.t}}" size="18rpx" />
                <text wx:elif="{{iconTheme === 'emoji'}}" class="mp-emoji xs">{{item.houseIcon.e}}</text>
                <image wx:else class="mp-img-icon xs" src="/packageGames/monopoly/assets/monopoly-icons/{{item.houseIcon.i}}.png" />
              </block>
            </block>
          </view>
          <view class="mp-cell-name">{{item.name}}</view>
          <view wx:if="{{item.owner}}" class="mp-cell-owner" style="background:{{item.ownerColor}};"></view>
        </block>
        <block wx:else>
          <view wx:if="{{item.icon}}" class="mp-cell-icon">
            <t-icon wx:if="{{iconTheme === 'tdesign'}}" name="{{item.icon.t}}" size="32rpx" />
            <text wx:elif="{{iconTheme === 'emoji'}}" class="mp-emoji sm">{{item.icon.e}}</text>
            <image wx:else class="mp-img-icon sm" src="/packageGames/monopoly/assets/monopoly-icons/{{item.icon.i}}.png" />
          </view>
          <view class="mp-cell-build"></view>
          <view class="mp-cell-name">{{item.name}}</view>
        </block>
      </view>
      <!-- 中心 6×6:金额(上)+ 骰子(中)+ 工具按钮(下,分多行) -->
      <view class="mp-center">
        <view class="mp-center-cash">
          <view class="mp-player {{started && myTurn ? 'on' : ''}}">
            <text class="mp-player-name">{{myName}}</text>
            <text class="mp-player-cash">{{myCash}}</text>
            <text wx:if="{{mySavings > 0}}" class="mp-player-sav">存{{mySavings}}</text>
          </view>
          <text class="mp-vs">VS</text>
          <view class="mp-player {{started && !myTurn ? 'on' : ''}}">
            <text class="mp-player-name">{{peerName}}</text>
            <text class="mp-player-cash">{{peerCash}}</text>
            <text wx:if="{{peerSavings > 0}}" class="mp-player-sav">存{{peerSavings}}</text>
          </view>
        </view>
        <view class="mp-center-mid">
          <view wx:if="{{diceAnim}}" class="mp-dice" style="transform: rotate({{diceAnim.angle || 0}}deg);">{{diceAnim.v}}</view>
          <view wx:if="{{diceAnim && diceAnim.showHint}}" class="mp-dice-hint">前进 {{diceAnim.v}} 格</view>
        </view>
        <view class="mp-center-tools">
          <view class="mp-tool-row">
            <view class="mp-tool" bindtap="openRules"><t-icon name="info-circle" size="36rpx" /><text>玩法</text></view>
            <view class="mp-tool" bindtap="switchIconTheme" wx:if="{{started}}"><t-icon name="palette" size="36rpx" /><text>图标</text></view>
          </view>
          <view class="mp-tool-row" wx:if="{{!winner}}">
            <t-button theme="default" size="small" bind:tap="resign" wx:if="{{started}}">投降</t-button>
            <t-button theme="default" size="small" bind:tap="requestRestart">重来</t-button>
          </view>
        </view>
        <view wx:if="{{requestPending}}" class="mp-center-req">已请求重开 <text class="mp-link" bindtap="cancelReq">取消</text></view>
        <view wx:if="{{sellReqPending}}" class="mp-center-req">等对方买地 <text class="mp-link" bindtap="cancelSell">取消</text></view>
      </view>
      <!-- 棋子(绝对定位) -->
      <view wx:if="{{tokenMe}}" class="mp-token {{tokenMe.kind}}" style="left:{{tokenMe.x}}%;top:{{tokenMe.y}}%;transform:translate(-50%,-60%) translateY({{-tokenMe.hop || 0}}rpx);background:{{tokenMe.color}};"></view>
      <view wx:if="{{tokenPeer}}" class="mp-token {{tokenPeer.kind}}" style="left:{{tokenPeer.x}}%;top:{{tokenPeer.y}}%;transform:translate(-50%,-60%) translateY({{-tokenPeer.hop || 0}}rpx);background:{{tokenPeer.color}};"></view>
      <!-- 抽牌浮层 -->
      <view wx:if="{{cardAnim}}" class="mp-card-layer">
        <view wx:if="{{cardAnim.phase === 'shuffle'}}" class="mp-card-shuffle">
          <view class="mp-card-back">?</view>
          <view class="mp-card-shuffle-hint">洗牌中</view>
        </view>
        <view wx:else class="mp-card-reveal {{cardAnim.kind}}" style="transform: scaleX({{cardAnim.flip || 1}});">
          <view wx:if="{{cardAnim.face}}" class="mp-card-face {{cardAnim.kind}}">
            <view class="mp-card-title">{{cardAnim.kind === 'good' ? '好事' : '坏事'}}</view>
            <view class="mp-card-text">{{cardAnim.text}}</view>
          </view>
          <view wx:else class="mp-card-back">?</view>
        </view>
      </view>
      <!-- 事件特效横幅 -->
      <view wx:if="{{fx && !cardAnim}}" class="mp-fx {{fx.kind}}">{{fx.text}}</view>
      <!-- 胜利遮罩 -->
      <view wx:if="{{winner}}" class="mp-over-mask">
        <view class="mp-over-text">{{winnerText}}</view>
        <view class="mp-over-sub">点底部「再来」开始新一局</view>
      </view>
    </view>
    <view wx:if="{{!started}}" class="mp-empty">
      <view class="mp-title">大富翁</view>
      <view class="mp-mode-pick">
        <view class="mp-start" data-mode="classic" bindtap="startMatch">经典模式</view>
        <view class="mp-start casual" data-mode="casual" bindtap="startMatch">休闲模式</view>
      </view>
      <view class="muted small">经典=纯 Monopoly｜休闲=存款利息+整组折扣</view>
    </view>
  </view>

  <!-- 全部对局记录(主页面内滚动) -->
  <scroll-view scroll-y class="mp-log-box" enhanced show-scrollbar="{{false}}">
    <view wx:for="{{log}}" wx:key="index" class="ml-item {{index === 0 ? 'new' : ''}}">· {{item}}</view>
    <view wx:if="{{!log.length}}" class="muted small log-empty">还没有记录，掷骰开始吧</view>
  </scroll-view>

  <!-- 底部:银行(左1/3)+ 掷骰(右2/3) -->
  <view class="mp-roll-bar">
    <view class="mp-roll-bank" bindtap="openBank" wx:if="{{started}}"><t-icon name="shop" size="36rpx" /><text>银行</text></view>
    <t-button class="mp-roll-dice" wx:if="{{!winner}}" theme="primary" bind:tap="roll" loading="{{rolling}}" disabled="{{!myTurn}}">{{myTurn ? '掷骰子' : (started ? '等对方掷骰' : '开始后掷骰')}}</t-button>
    <t-button class="mp-roll-dice" wx:if="{{winner}}" theme="primary" bind:tap="requestRestart">再来一局</t-button>
  </view>

  <!-- 银行/资产面板 -->
  <view class="sf-mask {{bankOpen ? 'show' : ''}}" bindtap="closeBank"></view>
  <view class="bank-sheet {{bankOpen ? 'show' : ''}}" catchtap="noop">
    <view class="sf-title">银行 / 资产 <text class="mp-mode-mini {{mode === 'classic' ? 'classic' : 'casual'}}">{{mode === 'classic' ? '经典' : '休闲'}}</text></view>
    <view class="bk-sum">
      <view class="bk-sum-l">现金:{{myCashFmt}}<text wx:if="{{mode !== 'classic'}}">　存款:{{mySavingsFmt}}</text></view>
      <view class="bk-sum-r">地皮:{{myPropCount}}　抵押:{{myMortgagedCount}}</view>
    </view>
    <block wx:if="{{mode !== 'classic'}}">
      <view class="bk-label">存款(过起点 +5% 利息)</view>
      <view class="bk-btns">
        <view class="bk-btn" data-act="deposit" data-amt="100" bindtap="bankAct">存 100</view>
        <view class="bk-btn" data-act="deposit" data-amt="500" bindtap="bankAct">存 500</view>
        <view class="bk-btn" data-act="withdraw" data-amt="100000" bindtap="bankAct">全部取出</view>
      </view>
    </block>
    <view class="bk-label" wx:if="{{mySets.length}}">成套色组（集齐同色过路费翻倍，可整组升级{{mode !== 'classic' ? ' 打9折' : ''}}）</view>
    <view class="bk-btns" wx:if="{{mySets.length}}">
      <view class="bk-btn" wx:for="{{mySets}}" wx:key="group" data-group="{{item.group}}" bindtap="upgradeGroup">升级整组({{item.count}}块) -{{item.cost}}</view>
    </view>
    <view class="bk-label">我的地皮(抵押拿半价·抵押中不收租 / 卖银行 60% / 卖对方 80%)</view>
    <scroll-view scroll-y class="bk-props">
      <view wx:for="{{myProps}}" wx:key="idx" class="bk-prop {{item.mortgaged ? 'is-mort' : ''}}">
        <view class="bp-name">
          {{item.name}} <text class="muted small">Lv{{item.level + 1}}</text>
          <text wx:if="{{item.mortgaged}}" class="bp-mort-tag"><t-icon name="lock-on" size="22rpx" /> 已抵押</text>
        </view>
        <view class="bp-acts">
          <view wx:if="{{!item.mortgaged}}" class="bk-btn sm {{!myTurn ? 'disabled' : ''}}" data-idx="{{item.idx}}" bindtap="{{myTurn ? 'mortgageProp' : 'noop'}}">抵押 +{{item.mortgageValue}}</view>
          <view wx:else class="bk-btn sm" data-idx="{{item.idx}}" bindtap="redeemProp">赎回 -{{item.redeemValue}}</view>
          <view wx:if="{{item.canUpgrade}}" class="bk-btn sm {{!myTurn ? 'disabled' : ''}}" data-idx="{{item.idx}}" bindtap="{{myTurn ? 'upgradeOne' : 'noop'}}">升级 -{{item.upgradeCost}}</view>
          <view class="bk-btn sm {{!myTurn ? 'disabled' : ''}}" data-idx="{{item.idx}}" bindtap="{{myTurn ? 'sellToBank' : 'noop'}}">卖银行 +{{item.sellBank}}</view>
          <view class="bk-btn sm {{!myTurn ? 'disabled' : ''}}" data-idx="{{item.idx}}" bindtap="{{myTurn ? 'sellToPeer' : 'noop'}}">卖对方 {{item.sellPeer}}</view>
        </view>
      </view>
      <view wx:if="{{!myProps.length}}" class="muted small" style="padding:20rpx 0">还没有地皮</view>
    </scroll-view>
    <view class="sf-actions"><view class="sf-ok" bindtap="closeBank">关闭</view></view>
  </view>

  <game-rules game-key="monopoly" open="{{rulesOpen}}" bind:close="closeRules" />
  <roll-first open="{{rollFirst.open}}" result="{{rollFirst.result}}" my-name="{{myName}}" peer-name="{{peerName}}" />
</view>
