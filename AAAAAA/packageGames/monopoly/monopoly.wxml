<view class="theme-{{theme}} love-page mp-page">

  <view class="mp-board-wrap">
    <canvas wx:if="{{!rulesOpen}}" type="2d" id="board" class="mp-board"></canvas>
    <view wx:if="{{!started}}" class="mp-empty">
      <view class="mp-title">大富翁</view>
      <view class="mp-start" bindtap="startMatch">开始对局</view>
      <view class="muted small">买地收租 · 机会与突发事件 · 让对方破产即胜</view>
    </view>
    <view wx:if="{{winner}}" class="mp-over-mask"><view class="mp-over-text">{{winnerText}}</view></view>
  </view>

  <!-- 事件提示：固定高度槽位(不挤布局/不抖动)，棋盘下方无 canvas 必可见 -->
  <view class="mp-evt-slot">
    <view wx:if="{{fx}}" class="mp-evt {{fx.kind}}">
      <t-icon name="{{fx.kind === 'good' ? 'check-circle-filled' : 'close-circle-filled'}}" size="40rpx" />
      <text class="mp-evt-text">{{fx.text}}</text>
    </view>
  </view>

  <view class="mp-pair">
    <view class="mp-p me"><text class="mp-n">{{myName}}</text><text class="mp-cash">{{myCash}}</text></view>
    <view class="mp-p"><text class="mp-n">{{peerName}}</text><text class="mp-cash">{{peerCash}}</text></view>
  </view>

  <view wx:if="{{winner}}" class="mp-result">{{winnerText}}</view>
  <view wx:elif="{{started}}" class="mp-turn">{{myTurn ? '该你掷骰' : '等 ' + peerName + ' 掷骰'}}</view>
  <view wx:if="{{requestPending}}" class="mp-pending">已请求重开，等 {{peerName}} 同意 <text class="mp-link" bindtap="cancelReq">取消</text></view>

  <scroll-view scroll-y class="mp-log" enhanced show-scrollbar="{{false}}">
    <view wx:for="{{log}}" wx:key="index" class="mp-log-item {{index === 0 ? 'new' : ''}}">· {{item}}</view>
    <view wx:if="{{!log.length}}" class="muted small">掷骰后这里显示事件</view>
  </scroll-view>

  <view class="mp-actions">
    <t-button wx:if="{{!winner}}" theme="primary" block bind:tap="roll" loading="{{rolling}}" disabled="{{!myTurn}}">{{myTurn ? '掷骰子' : (started ? '等对方掷骰' : '开始后掷骰')}}</t-button>
    <view class="mp-row">
      <t-button theme="default" size="small" bind:tap="openRules">玩法</t-button>
      <t-button wx:if="{{started}}" theme="default" size="small" bind:tap="openBank">银行</t-button>
      <t-button wx:if="{{started && !winner}}" theme="default" size="small" bind:tap="resign">认输</t-button>
      <t-button theme="default" size="small" bind:tap="requestRestart">{{winner ? '再来一局' : '重新开局'}}</t-button>
    </view>
  </view>

  <!-- 抽牌：底部抽屉(普通 view，位于棋盘下方不被 canvas 挡)，保留洗牌+翻牌动画 -->
  <view wx:if="{{card}}" class="card-sheet {{card.kind}} {{card.drawing ? 'shuffling' : 'reveal'}}" catchtap="dismissCard">
    <view wx:if="{{card.drawing}}" class="cs-deck">
      <view class="cs-back b1"></view>
      <view class="cs-back b2"></view>
      <view class="cs-back b3"></view>
      <view class="cs-tip">洗牌中…</view>
    </view>
    <view wx:else class="cs-face">
      <view class="cs-title">{{card.kind === 'good' ? '好 事' : (card.kind === 'bad' ? '坏 事' : '事 件')}}</view>
      <view class="cs-text">{{card.text}}</view>
    </view>
  </view>

  <view wx:if="{{sellReqPending}}" class="mp-pending">等对方决定是否买你的地 <text class="mp-link" bindtap="cancelSell">取消</text></view>

  <!-- 银行/资产面板 -->
  <view class="sf-mask {{bankOpen ? 'show' : ''}}" bindtap="closeBank"></view>
  <view class="bank-sheet {{bankOpen ? 'show' : ''}}" catchtap="noop">
    <view class="sf-title">银行 / 资产</view>
    <view class="bk-sum">现金 {{myCash}} 存款 {{mySavings}} 贷款 {{myLoan}}</view>
    <view class="bk-label">存款(过起点 +5% 利息)</view>
    <view class="bk-btns">
      <view class="bk-btn" data-act="deposit" data-amt="100" bindtap="bankAct">存 100</view>
      <view class="bk-btn" data-act="deposit" data-amt="500" bindtap="bankAct">存 500</view>
      <view class="bk-btn" data-act="withdraw" data-amt="100000" bindtap="bankAct">全部取出</view>
    </view>
    <view class="bk-label">贷款(借 200 实欠 220，过起点 +10% 利息)</view>
    <view class="bk-btns">
      <view class="bk-btn" data-act="borrow" bindtap="bankAct">贷款 +200</view>
      <view class="bk-btn" data-act="repay" bindtap="bankAct">还款</view>
    </view>
    <view class="bk-label">我的地皮（卖银行 60% / 卖对方 80%）</view>
    <scroll-view scroll-y class="bk-props">
      <view wx:for="{{myProps}}" wx:key="idx" class="bk-prop">
        <view class="bp-name">{{item.name}} <text class="muted small">Lv{{item.level + 1}}</text></view>
        <view class="bp-acts">
          <view class="bk-btn sm" data-idx="{{item.idx}}" bindtap="sellToBank">卖银行 +{{item.sellBank}}</view>
          <view class="bk-btn sm" data-idx="{{item.idx}}" bindtap="sellToPeer">卖对方 {{item.sellPeer}}</view>
        </view>
      </view>
      <view wx:if="{{!myProps.length}}" class="muted small" style="padding:20rpx 0">还没有地皮</view>
    </scroll-view>
    <view class="sf-actions"><view class="sf-ok" bindtap="closeBank">关闭</view></view>
  </view>

  <game-rules game-key="monopoly" open="{{rulesOpen}}" bind:close="closeRules" />
</view>
