page { background-color: var(--bg-1); }
.t-page { padding: 12rpx 20rpx calc(12rpx + env(safe-area-inset-bottom)); height: 100vh; box-sizing: border-box; display: flex; flex-direction: column; overflow: hidden; }

.t-top { display: flex; align-items: baseline; justify-content: space-between; padding: 0 6rpx 10rpx; }
.t-score { font-size: 50rpx; font-weight: 800; color: var(--primary-deep); line-height: 1; }
.t-meta { display: flex; flex-direction: column; align-items: flex-end; gap: 2rpx; font-size: 22rpx; color: var(--text-soft); }
.t-finish { margin-top: 4rpx; padding: 2rpx 14rpx; border-radius: 14rpx; background: var(--chip); color: var(--primary-deep); font-size: 22rpx; }

.t-screen { flex: 1; min-height: 0; position: relative; border-radius: 18rpx; overflow: hidden; background: var(--card); box-shadow: 0 6rpx 24rpx var(--card-shadow); }
.t-board { width: 100%; height: 100%; }
.t-mask { position: absolute; inset: 0; background: rgba(0,0,0,.5); display: flex; flex-direction: column; align-items: center; justify-content: center; gap: 12rpx; }
.tm-text { color: #fff; font-size: 40rpx; font-weight: 800; }
.tm-sub { color: rgba(255,255,255,.85); font-size: 28rpx; }
.tm-btn { margin-top: 6rpx; padding: 14rpx 44rpx; border-radius: 36rpx; background: var(--primary); color: #fff; font-size: 28rpx; }

/* 手柄：左方向 + 右动作（旋转在右） */
.t-pad { display: flex; align-items: stretch; justify-content: space-between; gap: 24rpx; margin-top: 14rpx; }
.t-dir { display: flex; gap: 12rpx; }
.t-btn { width: 96rpx; height: 96rpx; border-radius: 20rpx; background: var(--card); color: var(--primary-deep); display: flex; align-items: center; justify-content: center; box-shadow: 0 4rpx 14rpx var(--card-shadow); }
.t-btn:active { transform: scale(.92); background: var(--chip); }
.t-btn.primary { background: var(--primary); color: #fff; }
.t-btn.sm { width: 84rpx; height: 84rpx; color: var(--text-soft); }
.t-lab { font-size: 20rpx; margin-left: 4rpx; }
.t-act { display: flex; flex-direction: column; align-items: flex-end; gap: 10rpx; }
.t-actrow { display: flex; gap: 10rpx; }
