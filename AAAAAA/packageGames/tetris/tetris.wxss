page { background-color: var(--bg-1); }
.t-page { padding: 0; }   /* 游戏机外壳自管内边距 */

/* —— 游戏机机身 —— */
.console {
  margin: 20rpx; padding: 28rpx 24rpx calc(28rpx + env(safe-area-inset-bottom));
  border-radius: 40rpx;
  background: linear-gradient(160deg, var(--card), var(--chip));
  box-shadow: 0 16rpx 48rpx var(--card-shadow);
}

/* —— 屏幕（深色内嵌） —— */
.screen {
  background: linear-gradient(160deg, #2b2b3a, #1a1a28);
  border-radius: 24rpx; padding: 20rpx;
  box-shadow: inset 0 4rpx 16rpx rgba(0,0,0,.45);
}
.scr-top { display: flex; align-items: baseline; justify-content: space-between; margin-bottom: 14rpx; padding: 0 6rpx; }
.scr-score { font-size: 56rpx; font-weight: 800; color: #fff; line-height: 1; }
.scr-meta { display: flex; flex-direction: column; align-items: flex-end; gap: 2rpx; font-size: 22rpx; color: rgba(255,255,255,.6); }

.t-board-wrap { position: relative; display: flex; justify-content: center; }
.t-board { width: 30vh; height: 60vh; border-radius: 12rpx; }

/* 结束/暂停遮罩 */
.over-mask {
  position: absolute; left: 0; top: 0; right: 0; bottom: 0; border-radius: 12rpx;
  background: rgba(0,0,0,0.55); display: flex; flex-direction: column; align-items: center; justify-content: center; gap: 12rpx;
  animation: tFadeIn .3s ease both;
}
@keyframes tFadeIn { from { opacity: 0; transform: scale(1.04); } to { opacity: 1; transform: scale(1); } }
.over-text { color: #fff; font-size: 40rpx; font-weight: 800; }
.over-score { color: rgba(255,255,255,0.85); font-size: 28rpx; }
.over-btn { margin-top: 8rpx; padding: 14rpx 40rpx; border-radius: 36rpx; background: var(--primary); color: #fff; font-size: 28rpx; transition: transform .12s ease; }
.over-btn:active { transform: scale(.95); opacity: .9; }

/* —— 手柄：十字方向键 + 动作键 —— */
.pad { display: flex; align-items: center; justify-content: space-between; margin-top: 36rpx; padding: 0 8rpx; }
.dpad { display: grid; grid-template-columns: repeat(3, 84rpx); grid-template-rows: repeat(3, 84rpx); gap: 6rpx; }
.dp-cell { width: 84rpx; height: 84rpx; }
.dp-btn {
  width: 84rpx; height: 84rpx; background: var(--card); color: var(--primary-deep);
  display: flex; align-items: center; justify-content: center; border-radius: 16rpx;
  box-shadow: 0 4rpx 12rpx var(--card-shadow); transition: transform .1s ease, background .12s ease;
}
.dp-btn:active { transform: scale(.9); background: var(--chip); }
.dp-core { width: 84rpx; height: 84rpx; display: flex; align-items: center; justify-content: center; }
.dp-core::after { content: ''; width: 22rpx; height: 22rpx; border-radius: 50%; background: var(--border); }

.abtns { display: flex; flex-direction: column; gap: 22rpx; align-items: center; }
.abtn {
  width: 116rpx; height: 116rpx; border-radius: 50%; background: var(--card); color: var(--primary-deep);
  display: flex; flex-direction: column; align-items: center; justify-content: center; gap: 2rpx;
  box-shadow: 0 6rpx 18rpx var(--card-shadow); font-size: 20rpx; transition: transform .1s ease;
}
.abtn:active { transform: scale(.9); }
.abtn.sm { width: 92rpx; height: 92rpx; color: var(--text-soft); }
.abtn.primary { background: var(--primary); color: #fff; }
