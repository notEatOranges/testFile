.t-page { display: flex; flex-direction: column; align-items: center; padding-top: 24rpx; }

.t-top { display: flex; align-items: center; gap: 24rpx; margin-bottom: 24rpx; }
.t-score { display: flex; flex-direction: column; align-items: center; padding: 8rpx 28rpx; border-radius: 16rpx; background: var(--card); box-shadow: 0 6rpx 20rpx var(--card-shadow); }
.t-score .lbl { font-size: 22rpx; color: var(--text-soft); }
.t-score .val { font-size: 40rpx; font-weight: 800; color: var(--primary-deep); }
.t-meta { display: flex; flex-direction: column; gap: 4rpx; font-size: 24rpx; color: var(--text-soft); }

.t-board-wrap { position: relative; }
.t-board { width: 52vw; height: 104vw; border-radius: 12rpx; }
.over-mask {
  position: absolute; left: 0; top: 0; right: 0; bottom: 0; border-radius: 12rpx;
  background: rgba(0,0,0,0.45); display: flex; flex-direction: column; align-items: center; justify-content: center; gap: 12rpx;
}
.over-text { color: #fff; font-size: 40rpx; font-weight: 800; }
.over-score { color: rgba(255,255,255,0.85); font-size: 28rpx; }
.over-btn { margin-top: 8rpx; padding: 14rpx 40rpx; border-radius: 36rpx; background: var(--primary); color: #fff; font-size: 28rpx; }

.t-ctrls { display: flex; align-items: center; gap: 18rpx; margin-top: 36rpx; }
.t-btn {
  width: 96rpx; height: 96rpx; border-radius: 50%; background: var(--card); color: var(--primary-deep);
  display: flex; align-items: center; justify-content: center; box-shadow: 0 6rpx 20rpx var(--card-shadow);
}
.t-btn:active { background: var(--chip); }
.t-btn.sm { width: 84rpx; height: 84rpx; color: var(--text-soft); }
