<view class="theme-{{theme}} love-page t-page">
  <view class="console">

    <!-- 屏幕：分数 + 棋盘 -->
    <view class="screen">
      <view class="scr-top">
        <text class="scr-score">{{score}}</text>
        <view class="scr-meta">
          <text>第 {{level}} 关 · {{lines}} 行</text>
          <text>最高 {{best}}</text>
        </view>
      </view>
      <view class="t-board-wrap">
        <canvas type="2d" id="board" class="t-board"></canvas>
        <view wx:if="{{over}}" class="over-mask">
          <view class="over-text">游戏结束</view>
          <view class="over-score">{{score}} 分</view>
          <view class="over-btn" bindtap="restart">再来一局</view>
        </view>
        <view wx:if="{{paused && !over}}" class="over-mask">
          <view class="over-text">已暂停</view>
          <view class="over-btn" bindtap="togglePause">继续</view>
        </view>
      </view>
    </view>

    <!-- 手柄：左十字方向键 + 右动作键 -->
    <view class="pad">
      <view class="dpad">
        <view class="dp-cell"></view>
        <view class="dp-btn" bindtap="rotate"><t-icon name="refresh" size="40rpx" /></view>
        <view class="dp-cell"></view>
        <view class="dp-btn" bindtap="left"><t-icon name="chevron-left" size="44rpx" /></view>
        <view class="dp-core"></view>
        <view class="dp-btn" bindtap="right"><t-icon name="chevron-right" size="44rpx" /></view>
        <view class="dp-cell"></view>
        <view class="dp-btn" bindtap="softDrop"><t-icon name="chevron-down" size="44rpx" /></view>
        <view class="dp-cell"></view>
      </view>
      <view class="abtns">
        <view class="abtn primary" bindtap="hardDrop"><t-icon name="arrow-down" size="44rpx" /><text>硬降</text></view>
        <view class="abtn sm" bindtap="togglePause"><t-icon name="{{paused ? 'play' : 'pause'}}" size="40rpx" /></view>
      </view>
    </view>

  </view>
</view>
