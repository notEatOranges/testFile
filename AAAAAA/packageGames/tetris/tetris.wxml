<view class="theme-{{theme}} love-page t-page">
  <view class="t-top">
    <text class="t-score">{{score}}</text>
    <view class="t-meta">
      <text>第 {{level}} 关 · {{lines}} 行</text>
      <text>最高 {{best}}</text>
      <text class="t-finish" bindtap="finishGame">结束记分</text>
    </view>
  </view>

  <view class="t-screen">
    <canvas type="2d" id="board" class="t-board"></canvas>
    <view wx:if="{{over}}" class="t-mask">
      <view class="tm-text">游戏结束</view>
      <view class="tm-sub">{{score}} 分</view>
      <view class="tm-btn" bindtap="restart">再来一局</view>
    </view>
    <view wx:if="{{paused && !over}}" class="t-mask">
      <view class="tm-text">已暂停</view>
      <view class="tm-btn" bindtap="togglePause">继续</view>
    </view>
  </view>

  <view class="t-pad">
    <!-- 左:十字方向键(上=旋转 / 左右=移动 / 下=软降) -->
    <view class="t-dpad">
      <view class="t-btn t-d-up" bindtap="rotate"><t-icon name="chevron-up" size="44rpx" /></view>
      <view class="t-btn t-d-left" bindtap="left"><t-icon name="chevron-left" size="44rpx" /></view>
      <view class="t-btn t-d-down" bindtap="softDrop"><t-icon name="chevron-down" size="44rpx" /></view>
      <view class="t-btn t-d-right" bindtap="right"><t-icon name="chevron-right" size="44rpx" /></view>
    </view>

    <!-- 右:直降+暂停(左,小) → 大间距 → 旋转(右,大) -->
    <view class="t-act">
      <view class="t-actrow">
        <view class="t-btn sm t-drop" bindtap="hardDrop"><t-icon name="arrow-down" size="36rpx" /></view>
        <view class="t-btn sm" bindtap="togglePause"><t-icon name="{{paused ? 'play' : 'pause'}}" size="36rpx" /></view>
      </view>
      <view class="t-btn primary rot" bindtap="rotate"><t-icon name="refresh" size="56rpx" /><text class="t-lab">旋转</text></view>
    </view>
  </view>
</view>
