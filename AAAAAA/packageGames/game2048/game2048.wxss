.g-page { display: flex; flex-direction: column; align-items: center; padding-top: 40rpx; }

.g-bar { display: flex; align-items: center; gap: 18rpx; margin-bottom: 32rpx; }
.g-score {
  display: flex; flex-direction: column; align-items: center; justify-content: center;
  min-width: 150rpx; padding: 12rpx 24rpx; border-radius: 18rpx; background: var(--card); box-shadow: 0 6rpx 20rpx var(--card-shadow);
}
.g-score .lbl { font-size: 22rpx; color: var(--text-soft); }
.g-score .val { font-size: 40rpx; font-weight: 800; color: var(--primary-deep); }
.g-score.best .val { color: var(--text); }
.g-restart {
  width: 76rpx; height: 76rpx; border-radius: 50%; background: var(--primary); color: #fff;
  display: flex; align-items: center; justify-content: center; box-shadow: 0 6rpx 20rpx var(--card-shadow);
}

.board-wrap { position: relative; }
.board { width: 86vw; height: 86vw; max-width: 620rpx; max-height: 620rpx; }
.over-mask {
  position: absolute; left: 0; top: 0; right: 0; bottom: 0; border-radius: 16rpx;
  background: rgba(0,0,0,0.45); display: flex; flex-direction: column; align-items: center; justify-content: center; gap: 12rpx;
}
.over-text { color: #fff; font-size: 44rpx; font-weight: 800; }
.over-score { color: rgba(255,255,255,0.85); font-size: 28rpx; }
.over-btn { margin-top: 10rpx; padding: 16rpx 44rpx; border-radius: 36rpx; background: var(--primary); color: #fff; font-size: 28rpx; }

.g-tip { margin-top: 32rpx; }
