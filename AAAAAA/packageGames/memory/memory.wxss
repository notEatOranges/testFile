.mem-page { display: flex; flex-direction: column; align-items: center; padding-top: 24rpx; }

.mem-bar { display: flex; align-items: center; gap: 24rpx; margin-bottom: 18rpx; }
.seat { display: flex; flex-direction: column; align-items: center; gap: 2rpx; min-width: 190rpx; padding: 14rpx 20rpx; border-radius: 18rpx; background: var(--card); box-shadow: 0 6rpx 20rpx var(--card-shadow); border-top: 6rpx solid transparent; }
.seat.red { border-top-color: #e85a86; }
.seat.blue { border-top-color: #3a86ff; }
.seat-name { font-size: 28rpx; font-weight: 600; color: var(--text); }
.seat-score { font-size: 44rpx; font-weight: 800; color: var(--primary-deep); }
.vs { font-size: 26rpx; color: var(--text-soft); font-weight: 700; }

.mem-result { font-size: 36rpx; font-weight: 800; color: var(--primary-deep); margin-bottom: 8rpx; }
.mem-tip { margin-bottom: 8rpx; }
.mem-pending { display: flex; align-items: center; gap: 16rpx; margin-bottom: 10rpx; padding: 12rpx 22rpx; border-radius: 18rpx; background: var(--card); box-shadow: 0 4rpx 16rpx var(--card-shadow); font-size: 25rpx; color: var(--primary-deep); }
.mem-link { margin-left: auto; color: var(--text-soft); padding: 4rpx 10rpx; }

.mem-grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 16rpx; width: 86vw; max-width: 600rpx; }
.mcard {
  position: relative; aspect-ratio: 1 / 1; border-radius: 18rpx;
  box-shadow: 0 6rpx 20rpx var(--card-shadow); transform-style: preserve-3d;
}
.mc-back, .mc-face {
  position: absolute; left: 0; top: 0; width: 100%; height: 100%;
  display: flex; align-items: center; justify-content: center; border-radius: 18rpx;
  backface-visibility: hidden; transition: transform .25s;
}
.mc-back { background: linear-gradient(135deg, var(--primary), var(--primary-deep)); color: rgba(255,255,255,.85); }
.mc-face { background: var(--card); color: var(--primary-deep); transform: rotateY(180deg); }
.mcard.up .mc-back { transform: rotateY(180deg); }
.mcard.up .mc-face { transform: rotateY(0); }
.mcard.matched .mc-face { background: var(--chip); color: var(--primary); }
.mcard.matched { opacity: 0.7; }

.mem-empty { display: flex; flex-direction: column; align-items: center; gap: 14rpx; padding: 90rpx 0; }
.me-text { font-size: 30rpx; color: var(--text-soft); }
.me-btn { padding: 16rpx 48rpx; border-radius: 36rpx; background: var(--primary); color: #fff; font-size: 28rpx; }

.mem-actions { display: flex; gap: 18rpx; margin-top: 28rpx; }
