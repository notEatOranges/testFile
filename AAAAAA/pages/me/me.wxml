<view class="theme-{{theme}} love-page me-page">

  <view class="me-profile love-card">
    <image class="me-av" src="{{avatar || '/assets/images/{{role}}.jpg'}}" mode="aspectFill" />
    <view class="me-info">
      <view class="me-nick">{{nick || roleFull}}</view>
      <view class="me-sub muted small">空间码 {{roomCode}} · {{roleFull}}</view>
    </view>
  </view>

  <view class="me-group love-card">
    <view class="me-cell" bindtap="copyInvite">
      <view class="mc-ic"><t-icon name="user-add" size="40rpx" /></view>
      <view class="mc-text">
        <view class="mc-title">邀请码</view>
        <view class="mc-sub muted small">发给 ta 加入空间</view>
      </view>
      <view class="mc-code">{{inviteCode}}</view>
    </view>
    <view class="me-cell" bindtap="pickTheme">
      <view class="mc-ic"><t-icon name="palette" size="40rpx" /></view>
      <view class="mc-text"><view class="mc-title">换主题</view></view>
      <view class="mc-arrow"><t-icon name="chevron-right" size="36rpx" /></view>
    </view>
    <view class="me-cell" bindtap="onNotifyTap">
      <view class="mc-ic"><t-icon name="notification" size="40rpx" /></view>
      <view class="mc-text"><view class="mc-title">消息通知</view></view>
      <view class="mc-arrow"><t-icon name="chevron-right" size="36rpx" /></view>
    </view>
  </view>

  <view class="me-group love-card">
    <view class="me-cell danger" bindtap="logout">
      <view class="mc-ic"><t-icon name="logout" size="40rpx" /></view>
      <view class="mc-text"><view class="mc-title">退出空间</view></view>
    </view>
  </view>

  <!-- 主题切换半屏弹层 -->
  <view class="theme-mask {{themeSheet ? 'show' : ''}}" bindtap="closeTheme"></view>
  <view class="theme-sheet {{themeSheet ? 'show' : ''}}">
    <view class="sheet-handle"></view>
    <view class="sheet-title">选择主题</view>
    <view class="sheet-sub muted small">8 套马卡龙配色，点击即时切换</view>
    <view class="theme-grid">
      <view wx:for="{{themeList}}" wx:key="key" class="theme-chip {{theme === item.key ? 'sel' : ''}}" data-key="{{item.key}}" bindtap="selectTheme">
        <view class="chip-color" style="background: linear-gradient(135deg, {{item.primary}}, {{item.primaryDeep}})"></view>
        <view class="chip-name">{{item.name}}</view>
        <view wx:if="{{theme === item.key}}" class="chip-check"><t-icon name="check" size="24rpx" /></view>
      </view>
    </view>
  </view>
</view>
