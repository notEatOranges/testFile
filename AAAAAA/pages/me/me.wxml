<view class="theme-{{theme}} love-page me-page">

  <view class="me-profile love-card" bindtap="openEdit">
    <view class="av-wrap">
      <image class="me-av" src="{{avatar || '/assets/images/' + role + '.jpg'}}" mode="aspectFill" />
      <view class="av-badge"><t-icon name="camera" size="24rpx" /></view>
    </view>
    <view class="me-info">
      <view class="me-nick">{{nick || '点这里设置网名'}}</view>
      <view class="me-sub muted small">空间码 {{roomCode}} · 点此改网名头像</view>
    </view>
    <view class="me-edit-arrow"><t-icon name="edit-1" size="36rpx" /></view>
  </view>

  <view class="me-group love-card">
    <view class="me-cell" bindtap="copyInvite">
      <view class="mc-ic"><t-icon name="user-add" size="40rpx" /></view>
      <view class="mc-text">
        <view class="mc-title">邀请码</view>
        <view class="mc-sub muted small">发给 ta 加入空间</view>
      </view>
      <view class="mc-code">{{inviteCode}}</view>
    </view>
    <view class="me-cell" bindtap="pickTheme">
      <view class="mc-ic"><t-icon name="palette" size="40rpx" /></view>
      <view class="mc-text"><view class="mc-title">换主题</view></view>
      <view class="mc-arrow"><t-icon name="chevron-right" size="36rpx" /></view>
    </view>
    <view class="me-cell" bindtap="onNotifyTap">
      <view class="mc-ic"><t-icon name="notification" size="40rpx" /></view>
      <view class="mc-text"><view class="mc-title">消息通知</view></view>
      <view class="mc-arrow"><t-icon name="chevron-right" size="36rpx" /></view>
    </view>
    <view class="me-cell" bindtap="openPokeSuffix">
      <view class="mc-ic"><t-icon name="heart" size="40rpx" /></view>
      <view class="mc-text"><view class="mc-title">戳一戳后缀</view></view>
      <view class="mc-val muted small">{{pokeSuffix ? pokeSuffix : '未设置'}}</view>
      <view class="mc-arrow"><t-icon name="chevron-right" size="36rpx" /></view>
    </view>
  </view>

  <view class="me-group love-card">
    <view class="me-cell danger" bindtap="logout">
      <view class="mc-ic"><t-icon name="logout" size="40rpx" /></view>
      <view class="mc-text"><view class="mc-title">退出空间</view></view>
    </view>
  </view>

  <!-- 主题切换半屏弹层 -->
  <view class="theme-mask {{themeSheet ? 'show' : ''}}" bindtap="closeTheme"></view>
  <view class="theme-sheet {{themeSheet ? 'show' : ''}}">
    <view class="sheet-handle"></view>
    <view class="sheet-title">选择主题</view>
    <view class="sheet-sub muted small">8 套马卡龙配色，点击即时切换</view>
    <view class="theme-grid">
      <view wx:for="{{themeList}}" wx:key="key" class="theme-chip {{theme === item.key ? 'sel' : ''}}" data-key="{{item.key}}" bindtap="selectTheme">
        <view class="chip-color" style="background: linear-gradient(135deg, {{item.primary}}, {{item.primaryDeep}})"></view>
        <view class="chip-name">{{item.name}}</view>
        <view wx:if="{{theme === item.key}}" class="chip-check"><t-icon name="check" size="24rpx" /></view>
      </view>
    </view>
  </view>

  <!-- 戳一戳后缀输入浮层 -->
  <view class="sf-mask {{suffixOpen ? 'show' : ''}}" bindtap="closeSuffix"></view>
  <view class="sf-sheet {{suffixOpen ? 'show' : ''}}" catchtap="noop">
    <view class="sf-title">我的戳一戳后缀</view>
    <view class="sf-sub muted small">戳 ta 时会带上这句话，如「并说想你」</view>
    <input class="sf-input" placeholder="留空就是轻轻戳一下" value="{{suffixInput}}" maxlength="12" bindinput="onSuffixInput" confirm-type="done" bindconfirm="confirmSuffix" />
    <view class="sf-actions">
      <view class="sf-cancel" bindtap="closeSuffix">取消</view>
      <view class="sf-ok" bindtap="confirmSuffix">保存</view>
    </view>
  </view>

  <!-- 编辑资料浮层：网名 + 头像 -->
  <view class="sf-mask {{editOpen ? 'show' : ''}}" bindtap="closeEdit"></view>
  <view class="sf-sheet {{editOpen ? 'show' : ''}}" catchtap="noop">
    <view class="sf-title">编辑我的资料</view>
    <view class="sf-sub muted small">改完对方会实时看到你的新网名和头像</view>
    <view class="ep-avatar" catchtap="pickAvatar">
      <image class="ep-av" src="{{editAvatar || '/assets/images/' + role + '.jpg'}}" mode="aspectFill" />
      <view class="ep-av-tip"><t-icon name="camera" size="28rpx" /><text>换头像</text></view>
    </view>
    <input class="sf-input" placeholder="给自己起个网名" value="{{editNick}}" maxlength="12" bindinput="onEditNick" confirm-type="done" />
    <view class="sf-actions">
      <view class="sf-cancel" bindtap="closeEdit">取消</view>
      <view class="sf-ok {{savingProfile ? 'disabled' : ''}}" catchtap="saveProfile">{{savingProfile ? '保存中' : '保存'}}</view>
    </view>
  </view>
</view>
