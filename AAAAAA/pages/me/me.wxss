.me-page { padding-top: 24rpx; padding-bottom: calc(120rpx + env(safe-area-inset-bottom)); }

/* 资料 */
.me-profile { display: flex; align-items: center; gap: 20rpx; padding: 28rpx 32rpx; margin-bottom: 24rpx; }
.me-av { width: 96rpx; height: 96rpx; border-radius: 50%; border: 3rpx solid var(--border); background: var(--chip); }
.av-wrap { position: relative; width: 96rpx; height: 96rpx; flex-shrink: 0; }
.av-badge {
  position: absolute; right: -4rpx; bottom: -4rpx; width: 38rpx; height: 38rpx; border-radius: 50%;
  background: var(--primary); color: #fff; display: flex; align-items: center; justify-content: center;
  border: 3rpx solid var(--card);
}
.me-info { flex: 1; min-width: 0; }
.me-edit-arrow { color: var(--text-soft); padding-left: 8rpx; }
.me-nick { font-size: 32rpx; font-weight: 600; color: var(--text); }
.me-sub { margin-top: 8rpx; }

/* 板块：每个 me-group 是一张独立卡片，之间用 margin 隔开 */
.me-group { padding: 6rpx 0; margin-bottom: 24rpx; overflow: hidden; }
.me-cell { display: flex; align-items: center; gap: 18rpx; padding: 22rpx 28rpx; }
.me-group .me-cell + .me-cell { border-top: 1rpx solid var(--border); }   /* 同板块内 cell 分隔线 */
.me-cell:active { background: var(--chip); }
.mc-ic {
  width: 60rpx; height: 60rpx; border-radius: 16rpx; flex-shrink: 0;
  background: var(--chip); color: var(--primary);
  display: flex; align-items: center; justify-content: center;
}
.mc-text { flex: 1; min-width: 0; }
.mc-title { font-size: 29rpx; color: var(--text); }
.mc-sub { margin-top: 4rpx; }
.mc-code { font-size: 30rpx; font-weight: 700; letter-spacing: 4rpx; color: var(--primary-deep); font-family: monospace; }
.mc-val { font-size: 24rpx; color: var(--text-soft); max-width: 220rpx; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
.mc-arrow { color: var(--text-soft); }
.me-cell.danger .mc-ic { color: #e85a86; }
.me-cell.danger .mc-title { color: #e85a86; }

/* 主题切换半屏弹层（z-index 提到 tabBar 之上，避免被底部导航遮挡） */
.theme-mask { position: fixed; left: 0; top: 0; right: 0; bottom: 0; z-index: 200; background: rgba(0,0,0,.35); opacity: 0; pointer-events: none; transition: opacity .2s; }
.theme-mask.show { opacity: 1; pointer-events: auto; }
.theme-sheet { position: fixed; left: 0; right: 0; bottom: 0; z-index: 201; background: var(--card); border-radius: 28rpx 28rpx 0 0; padding: 16rpx 32rpx calc(36rpx + env(safe-area-inset-bottom)); transform: translateY(110%); transition: transform .26s cubic-bezier(.2,.8,.2,1); box-shadow: 0 -8rpx 32rpx var(--card-shadow); }
.theme-sheet.show { transform: translateY(0); }
.sheet-handle { width: 64rpx; height: 8rpx; border-radius: 4rpx; background: var(--border); margin: 0 auto 18rpx; }
.sheet-title { font-size: 32rpx; font-weight: 700; color: var(--text); }
.sheet-sub { margin-top: 6rpx; margin-bottom: 26rpx; }
.theme-grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 20rpx; }
.theme-chip { display: flex; flex-direction: column; align-items: center; gap: 10rpx; padding: 14rpx 0 16rpx; border-radius: 18rpx; border: 2rpx solid transparent; position: relative; }
.theme-chip.sel { border-color: var(--primary); background: var(--chip); }
.chip-color { width: 72rpx; height: 72rpx; border-radius: 50%; box-shadow: 0 4rpx 14rpx var(--card-shadow); }
.chip-name { font-size: 22rpx; color: var(--text-soft); }
.theme-chip.sel .chip-name { color: var(--primary-deep); font-weight: 600; }
.chip-check { position: absolute; top: 8rpx; right: 14rpx; width: 32rpx; height: 32rpx; border-radius: 50%; background: var(--primary-deep); color: #fff; display: flex; align-items: center; justify-content: center; }

/* 戳一戳后缀输入浮层（居中） */
.sf-mask { position: fixed; left: 0; top: 0; right: 0; bottom: 0; z-index: 200; background: rgba(0,0,0,.35); opacity: 0; pointer-events: none; transition: opacity .2s; }
.sf-mask.show { opacity: 1; pointer-events: auto; }
.sf-sheet {
  position: fixed; left: 48rpx; right: 48rpx; top: 50%; z-index: 201;
  transform: translate(0, -60%); background: var(--card); border-radius: 28rpx; padding: 32rpx;
  opacity: 0; pointer-events: none; transition: all .25s; box-shadow: 0 12rpx 40rpx var(--card-shadow);
}
.sf-sheet.show { opacity: 1; transform: translate(0, -50%); pointer-events: auto; }
.sf-title { font-size: 32rpx; font-weight: 700; color: var(--text); text-align: center; }
.sf-sub { text-align: center; margin-top: 8rpx; margin-bottom: 24rpx; }
.sf-input {
  width: 100%; box-sizing: border-box; height: 84rpx; line-height: 84rpx;
  padding: 0 24rpx; background: var(--chip); border-radius: 18rpx; font-size: 30rpx; color: var(--text);
}
.sf-actions { display: flex; gap: 20rpx; margin-top: 24rpx; }
.sf-cancel { flex: 1; text-align: center; padding: 20rpx 0; border-radius: 36rpx; background: var(--chip); color: var(--text-soft); font-size: 28rpx; }
.sf-ok { flex: 1; text-align: center; padding: 20rpx 0; border-radius: 36rpx; background: var(--primary); color: #fff; font-size: 28rpx; }
.sf-ok.disabled { opacity: 0.6; }

/* 编辑资料浮层：头像选择 */
.ep-avatar { display: flex; flex-direction: column; align-items: center; gap: 10rpx; margin: 8rpx 0 24rpx; }
.ep-av { width: 140rpx; height: 140rpx; border-radius: 50%; border: 3rpx solid var(--border); background: var(--chip); }
.ep-av-tip { display: flex; align-items: center; gap: 6rpx; font-size: 24rpx; color: var(--primary); }
