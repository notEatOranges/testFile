.main-page { padding-top: 24rpx; padding-bottom: calc(120rpx + env(safe-area-inset-bottom)); }

/* 启动 logo 页：满屏渐变 + 心跳爱心 logo */
.splash {
  position: fixed; left: 0; top: 0; right: 0; bottom: 0; z-index: 200;
  display: flex; flex-direction: column; align-items: center; justify-content: center;
  background: linear-gradient(160deg, var(--bg-1), var(--bg-2) 55%, var(--bg-3));
}
.splash-logo {
  width: 180rpx; height: 180rpx; border-radius: 50%;
  background: linear-gradient(135deg, var(--primary), var(--primary-deep)); color: #fff;
  display: flex; align-items: center; justify-content: center;
  box-shadow: 0 16rpx 48rpx var(--primary-soft);
  margin-bottom: 32rpx;
  animation: splashBeat 1.6s ease-in-out infinite;
}
@keyframes splashBeat { 0%, 100% { transform: scale(1); } 50% { transform: scale(1.07); } }
.splash-title { font-size: 46rpx; font-weight: 700; color: var(--text); letter-spacing: 6rpx; }
.splash-sub { font-size: 24rpx; margin-top: 10rpx; }
.splash-loading { margin-top: 48rpx; opacity: 0.55; }

.home-head { padding: 32rpx; margin-bottom: 24rpx; }
.hi-row { display: flex; align-items: center; gap: 20rpx; }
.hi-av { width: 88rpx; height: 88rpx; border-radius: 50%; border: 3rpx solid var(--border); background: var(--chip); }
.hi-text { flex: 1; min-width: 0; }
.hi-title { font-size: 32rpx; font-weight: 600; color: var(--text); }
.hi-sub { margin-top: 6rpx; }

.presence {
  display: flex; align-items: center; gap: 14rpx;
  margin-top: 28rpx; padding-top: 24rpx; border-top: 1rpx solid var(--border);
}
.dot { width: 16rpx; height: 16rpx; border-radius: 50%; background: #ccc; }
.dot.on { background: #4caf50; box-shadow: 0 0 10rpx #4caf50; }
.peer-av { width: 56rpx; height: 56rpx; border-radius: 50%; background: var(--chip); }
.peer-status { font-size: 26rpx; color: var(--text-soft); }
.peer-status.on { color: #4caf50; }

.grid-cards { display: grid; grid-template-columns: 1fr 1fr; gap: 20rpx; }
.nav-card {
  background: var(--card); border-radius: 24rpx; padding: 32rpx 24rpx;
  box-shadow: 0 6rpx 24rpx var(--card-shadow);
  display: flex; flex-direction: column; align-items: flex-start;
  transition: transform .15s;
}
.nav-card:active { transform: scale(0.97); }
.nav-ic {
  width: 72rpx; height: 72rpx; border-radius: 22rpx; margin-bottom: 18rpx;
  background: linear-gradient(135deg, var(--primary), var(--primary-deep));
  color: #fff;
  display: flex; align-items: center; justify-content: center;
  box-shadow: 0 6rpx 18rpx var(--primary-soft);
}
.nav-nt { font-size: 30rpx; font-weight: 600; color: var(--text); }
.nav-nd { margin-top: 6rpx; }

/* 首页订阅通知板块 */
.notify-card { display: flex; align-items: center; gap: 18rpx; margin-top: 24rpx; padding: 26rpx 28rpx; }
.notify-card:active { transform: scale(0.98); }
.notify-ic {
  width: 64rpx; height: 64rpx; border-radius: 18rpx; flex-shrink: 0;
  background: linear-gradient(135deg, var(--primary), var(--primary-deep)); color: #fff;
  display: flex; align-items: center; justify-content: center;
  box-shadow: 0 6rpx 16rpx var(--primary-soft);
}
.notify-text { flex: 1; min-width: 0; }
.notify-title { font-size: 30rpx; font-weight: 600; color: var(--text); }
.notify-sub { margin-top: 6rpx; }
.notify-arrow { color: var(--text-soft); }

/* 对方上线提示改用 TDesign t-message 组件，无需自定义样式 */
