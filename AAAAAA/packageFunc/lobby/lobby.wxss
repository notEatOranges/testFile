.lobby-page { padding-top: 16rpx; }
.lobby-head { text-align: center; margin: 16rpx 0 28rpx; }
.lh-title { font-size: 40rpx; font-weight: 800; color: var(--primary-deep); }
.lh-sub { margin-top: 8rpx; }
.game-grid { display: grid; grid-template-columns: repeat(2, 1fr); gap: 20rpx; }
.game-card {
  display: flex; flex-direction: column; align-items: center; justify-content: center; gap: 10rpx;
  padding: 40rpx 20rpx; min-height: 240rpx;
}
.game-card:active { transform: scale(0.97); }
.g-ic {
  width: 104rpx; height: 104rpx; border-radius: 28rpx; background: var(--chip); color: var(--primary);
  display: flex; align-items: center; justify-content: center;
}
.g-name { font-size: 30rpx; font-weight: 600; color: var(--text); }
.g-desc { text-align: center; }

/* 成绩榜入口 */
.lb-entry { display: flex; align-items: center; gap: 18rpx; padding: 22rpx 28rpx; margin-bottom: 24rpx; transition: transform .12s ease; }
.lb-entry:active { transform: scale(.99); }
.lb-ic { width: 64rpx; height: 64rpx; border-radius: 18rpx; background: var(--chip); color: var(--primary); display: flex; align-items: center; justify-content: center; flex-shrink: 0; }
.lb-info { flex: 1; }
.lb-title { font-size: 30rpx; font-weight: 600; color: var(--text); }
.lb-arrow { color: var(--text-soft); flex-shrink: 0; }
