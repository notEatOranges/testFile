.truth-page { padding-bottom: calc(60rpx + env(safe-area-inset-bottom)); }

/* 抽题 chips */
.draw-row { display: flex; flex-wrap: wrap; gap: 12rpx; margin-bottom: 16rpx; }
.draw-chip {
  display: flex; align-items: center; gap: 6rpx; padding: 14rpx 24rpx; border-radius: 30rpx;
  background: var(--card); color: var(--primary-deep); font-size: 26rpx; box-shadow: 0 4rpx 16rpx var(--card-shadow);
}
.draw-chip.busy { opacity: 0.6; }
.ghost-btn { margin-top: 0; }

/* 堆叠卡组 */
.deck-wrap { margin-top: 8rpx; }
.deck { position: relative; height: 300rpx; }
.deck-card {
  position: absolute; left: 0; right: 0; box-sizing: border-box;
  background: var(--card); border-radius: 24rpx; padding: 28rpx;
  box-shadow: 0 12rpx 36rpx var(--card-shadow);
}
.dc-cat { display: flex; align-items: center; gap: 8rpx; color: var(--primary); font-size: 24rpx; }
.dc-text { font-size: 34rpx; font-weight: 600; color: var(--text); line-height: 1.5; margin: 14rpx 0; }
.deck-empty { display: flex; flex-direction: column; align-items: center; justify-content: center; color: var(--primary); padding: 50rpx 0; }

/* 题目列表 */
.q-list { display: flex; flex-direction: column; gap: 14rpx; }
.q-card { padding: 24rpx 26rpx; }
.q-card.both { border-left: 6rpx solid var(--primary); }
.q-head { display: flex; align-items: center; justify-content: space-between; }
.q-cat { display: flex; align-items: center; gap: 6rpx; color: var(--primary); font-size: 24rpx; }
.q-status { font-size: 22rpx; color: var(--text-soft); }
.q-status.ok { color: var(--primary-deep); font-weight: 600; }
.q-text { font-size: 30rpx; color: var(--text); margin: 10rpx 0; line-height: 1.5; }
.q-foot { display: flex; justify-content: space-between; align-items: center; }
.q-del { color: var(--text-soft); padding: 4rpx 8rpx; }
.empty { text-align: center; padding: 60rpx 0; font-size: 26rpx; }

/* 回答弹层 */
.ans-cat { display: flex; align-items: center; gap: 8rpx; color: var(--primary); font-size: 24rpx; margin-bottom: 10rpx; }
.ans-q { font-size: 32rpx; font-weight: 600; color: var(--text); line-height: 1.5; margin-bottom: 18rpx; }
.ans-label { font-size: 24rpx; color: var(--text-soft); margin: 16rpx 0 8rpx; }
.ans-lock { color: var(--primary-deep); margin-left: 8rpx; }
.ans-readonly { background: var(--chip); border-radius: 16rpx; padding: 20rpx; font-size: 28rpx; color: var(--text); line-height: 1.5; }
.ans-peer { background: var(--chip); border-radius: 16rpx; padding: 20rpx; font-size: 28rpx; color: var(--text); line-height: 1.5; }
.ans-peer.ph { color: var(--text-soft); font-style: italic; }

/* 通用 chip（出题归类） */
.chip-row { display: flex; flex-wrap: wrap; gap: 12rpx; }
.chip {
  display: flex; align-items: center; gap: 6rpx; padding: 12rpx 22rpx; border-radius: 30rpx;
  background: var(--chip); color: var(--text-soft); font-size: 26rpx; border: 2rpx solid transparent;
}
.chip.sel { color: var(--primary-deep); border-color: var(--primary); font-weight: 600; }
.add-label { font-size: 24rpx; color: var(--text-soft); margin: 14rpx 0 10rpx; }
