<view class="theme-{{theme}} love-page truth-page">

  <!-- 抽题 / 出题 -->
  <view class="section-title">来一题</view>
  <view class="draw-row">
    <view wx:for="{{catList}}" wx:key="key" class="draw-chip {{drawing ? 'busy' : ''}}" data-k="{{item.key}}" bindtap="draw">
      <t-icon name="{{item.icon}}" size="30rpx" /><text>{{item.name}}</text>
    </view>
  </view>
  <t-button theme="primary" block class="love-btn" bind:tap="openAdd" icon="edit-1">我自己出一题</t-button>

  <!-- 堆叠卡组：等我回答（顶卡可左右滑切换，点击作答） -->
  <view class="section-title">等你回答 <text class="muted small">（左右滑切换，点开作答）</text></view>
  <view class="deck-wrap">
    <view wx:if="{{deckTop}}" class="deck">
      <!-- 后面的卡：静态堆叠，垫在底下 -->
      <view wx:for="{{deckRest}}" wx:key="id" class="deck-card rest"
            style="top:{{(index+1)*30}}rpx; left:{{(index+1)*18}}rpx; z-index:{{9-index}}; transform: scale({{1 - (index+1)*0.05}});">
        <view class="dc-cat"><t-icon name="{{item.catIcon}}" size="26rpx" /><text>{{item.catName}}</text></view>
        <view class="dc-text">{{item.text}}</view>
      </view>
      <!-- 顶卡：可滑动 + 点击 -->
      <view class="deck-card top" data-id="{{deckTop.id}}" bindtap="openAns"
            bindtouchstart="onDeckTouchStart" bindtouchmove="onDeckTouchMove" bindtouchend="onDeckTouchEnd"
            style="transform: scale(1) translateX({{topDx}}px) rotate({{topDx * 0.04}}deg);">
        <view class="dc-cat"><t-icon name="{{deckTop.catIcon}}" size="26rpx" /><text>{{deckTop.catName}}</text></view>
        <view class="dc-text">{{deckTop.text}}</view>
        <view class="dc-foot muted small">由 {{deckTop.creatorName || 'ta'}} 出题 · 点开回答 · 左右滑看下一题</view>
      </view>
    </view>
    <view wx:else class="love-card deck-empty">
      <t-icon name="heart" size="48rpx" />
      <view class="muted small" style="margin-top:12rpx">没有等你回答的题了，上面抽一题吧</view>
    </view>
  </view>

  <!-- 全部题目入口（列表收进弹层，主页更轻） -->
  <view class="all-entry love-card" bindtap="openAll">
    <view class="ae-ic"><t-icon name="list" size="40rpx" /></view>
    <view class="ae-info"><view class="ae-title">全部题目</view><view class="muted small">{{questions.length}} 题 · 查看与回答</view></view>
    <view class="he-arrow"><t-icon name="chevron-right" size="36rpx" /></view>
  </view>

  <!-- 回答弹层 -->
  <view class="sf-mask {{ansOpen ? 'show' : ''}}" bindtap="closeAns"></view>
  <view class="sf-sheet {{ansOpen ? 'show' : ''}}" catchtap="noop" wx:if="{{ansQ}}">
    <view class="ans-cat"><t-icon name="{{ansQ.catIcon}}" size="28rpx" /><text>{{ansQ.catName}} · {{ansQ.creatorName || 'ta'}} 出题</text></view>
    <view class="ans-q">{{ansQ.text}}</view>

    <view class="ans-label">我的回答 <text wx:if="{{ansLocked}}" class="ans-lock">已锁定</text></view>
    <t-textarea wx:if="{{!ansLocked}}" class="ans-area" placeholder="认真回答哦～" value="{{ansText}}" bind:change="onAnsInput" maxlength="200" indicator autosize="{{ true }}" />
    <view wx:else class="ans-readonly">{{ansText}}</view>

    <view class="ans-label">ta 的回答</view>
    <view wx:if="{{ansShowPeer}}" class="ans-peer">{{ansPeerText || '（ta 留了空）'}}</view>
    <view wx:else class="ans-peer ph">先回答才能看到 ta 的答案；ta 回答后你的答案会锁定</view>

    <view class="sf-actions">
      <view class="sf-cancel" bindtap="closeAns">关闭</view>
      <view wx:if="{{!ansLocked}}" class="sf-ok {{saving ? 'disabled' : ''}}" bindtap="submitAns">{{saving ? '保存中' : (ansQ.hasMy ? '保存修改' : '提交回答')}}</view>
    </view>
  </view>

  <!-- 出题弹层 -->
  <view class="sf-mask {{addOpen ? 'show' : ''}}" bindtap="closeAdd"></view>
  <view class="sf-sheet {{addOpen ? 'show' : ''}}" catchtap="noop">
    <view class="sf-title">出一题</view>
    <view class="sf-sub muted small">写给对方回答，写完点添加</view>
    <t-textarea class="ans-area" placeholder="你的问题…" value="{{addText}}" bind:change="onAddInput" maxlength="60" autosize="{{ true }}" />
    <view class="add-label">归类</view>
    <view class="chip-row">
      <view wx:for="{{catList}}" wx:key="key" class="chip {{addCat === item.key ? 'sel' : ''}}" data-k="{{item.key}}" bindtap="pickAddCat">
        <t-icon name="{{item.icon}}" size="26rpx" /><text>{{item.name}}</text>
      </view>
    </view>
    <view class="sf-actions">
      <view class="sf-cancel" bindtap="closeAdd">取消</view>
      <view class="sf-ok" bindtap="addCustom">添加</view>
    </view>
  </view>

  <!-- 全部题目弹层（半屏滚动列表） -->
  <view class="sf-mask {{allOpen ? 'show' : ''}}" bindtap="closeAll"></view>
  <view class="sf-sheet all-sheet {{allOpen ? 'show' : ''}}" catchtap="noop">
    <view class="sf-title">全部题目（{{questions.length}}）</view>
    <scroll-view scroll-y class="all-scroll">
      <view wx:for="{{questions}}" wx:key="id" class="love-card q-card {{item.both ? 'both' : ''}}" data-id="{{item.id}}" bindtap="openAns">
        <view class="q-head">
          <view class="q-cat"><t-icon name="{{item.catIcon}}" size="26rpx" /><text>{{item.catName}}</text></view>
          <text class="q-status {{item.both ? 'ok' : ''}}">{{item.statusText}}</text>
        </view>
        <view class="q-text">{{item.text}}</view>
        <view class="q-foot muted small">
          <text>由 {{item.creatorName || 'ta'}} 出题</text>
          <text class="q-del" data-id="{{item.id}}" catchtap="delQuestion">删除</text>
        </view>
      </view>
      <view wx:if="{{!questions.length}}" class="empty muted">还没有题目，抽一题或自己出一题吧</view>
    </scroll-view>
    <view class="sf-actions">
      <view class="sf-ok" bindtap="closeAll">关闭</view>
    </view>
  </view>
</view>
