.chat-page {
  position: relative;
  display: flex; flex-direction: column; height: 100vh;
  background: linear-gradient(160deg, var(--bg-1), var(--bg-2));
}
/* chat-list 不留右 padding（滚动条贴屏右）；内层 chat-inner 留右 padding 给内容 */
.chat-list { flex: 1; min-height: 0; padding: 16rpx 0 24rpx 24rpx; box-sizing: border-box; }
.chat-inner { padding-right: 40rpx; }

.chat-time { text-align: center; font-size: 22rpx; color: var(--text-soft); margin: 20rpx 0; }

/* 戳一戳记录：居中灰条 */
.chat-poke-row { display: flex; justify-content: center; margin: 14rpx 0; }
.chat-poke {
  display: inline-flex; align-items: center; gap: 6rpx;
  font-size: 22rpx; color: var(--text-soft);
  background: var(--chip); padding: 8rpx 20rpx; border-radius: 16rpx; line-height: 1.4;
}

.bubble-row { display: flex; align-items: flex-start; gap: 16rpx; margin: 18rpx 0; }
.bubble-row.cont { margin-top: 4rpx; }            /* 连续同 sender：紧凑、无头像无箭头 */
.avatar { width: 76rpx; height: 76rpx; border-radius: 50%; flex-shrink: 0; background: var(--chip); order: 1; }
.avatar.shake { animation: avatarShake .55s ease; }   /* 被戳抖动：只做旋转+轻微上下，不做横向位移，避免摇出列表可视区被裁剪 */
@keyframes avatarShake {
  0%, 100% { transform: rotate(0deg) translateY(0); }
  20% { transform: rotate(-9deg) translateY(-3rpx); }
  40% { transform: rotate(8deg) translateY(0); }
  60% { transform: rotate(-6deg) translateY(-2rpx); }
  80% { transform: rotate(5deg) translateY(0); }
}
.avatar-ph { background: transparent; }
.bubble-placeholder { width: 0; order: 2; }
.bubble-status { order: 2; display: flex; align-items: center; align-self: center; color: var(--text-soft); margin: 0 4rpx; }
.bubble-status.failed { color: #e85a86; }
.bubble {
  position: relative;
  order: 3; max-width: 60%; padding: 18rpx 24rpx; border-radius: 24rpx;
  background: var(--card); box-shadow: 0 4rpx 16rpx var(--card-shadow); word-break: break-all;
}

/* 自己消息：整行贴右 */
.bubble-row.me { justify-content: flex-end; }
.bubble-row.me .avatar { order: 3; }
.bubble-row.me .bubble { order: 2; background: var(--primary); color: #fff; }
.bubble-row.me .bubble-status { order: 1; }

/* 气泡小箭头，指向发送者（仅首条/有头像时，emoji 无箭头） */
.bubble-row.peer:not(.cont):not(.emoji-only) .bubble::before {
  content: ''; position: absolute; left: -12rpx; top: 24rpx;
  border-style: solid; border-width: 8rpx 12rpx 8rpx 0;
  border-color: transparent var(--card) transparent transparent;
}
.bubble-row.me:not(.cont):not(.emoji-only) .bubble::after {
  content: ''; position: absolute; right: -12rpx; top: 24rpx;
  border-style: solid; border-width: 8rpx 0 8rpx 12rpx;
  border-color: transparent transparent transparent var(--primary);
}

.bubble-text { font-size: 30rpx; line-height: 1.5; }
.bubble-time { display: block; font-size: 20rpx; opacity: 0.6; margin-top: 6rpx; }

/* 纯 emoji 大字，无气泡 */
.bubble-row.emoji-only .bubble { background: transparent; box-shadow: none; padding: 0; max-width: 80%; }
.emoji-bubble { line-height: 1.2; }
.emoji-big { font-size: 96rpx; }

.chat-empty { text-align: center; padding: 140rpx 0; font-size: 26rpx; }

/* 收到戳一戳的顶部提示 */
.poke-tip {
  position: absolute; top: 24rpx; left: 50%; transform: translate(-50%, -30rpx);
  display: flex; align-items: center; gap: 10rpx;
  padding: 14rpx 28rpx; border-radius: 36rpx;
  background: rgba(0,0,0,.55); color: #fff; font-size: 26rpx;
  opacity: 0; pointer-events: none; transition: all .25s; z-index: 20;
}
.poke-tip.show { opacity: 1; transform: translate(-50%, 0); }

/* 表情面板 */
.chat-emoji {
  height: 380rpx; overflow-y: auto; background: var(--card);
  border-top: 1rpx solid var(--border); padding: 16rpx; box-sizing: border-box;
  display: grid; grid-template-columns: repeat(8, 1fr); gap: 8rpx;
}
.chat-emoji::-webkit-scrollbar { width: 0; height: 0; display: none; }
.emoji-cell { text-align: center; font-size: 48rpx; padding: 12rpx 0; border-radius: 12rpx; line-height: 1.2; }
.emoji-cell:active { background: var(--chip); }

/* 输入栏：底部加安全边距，防小白条遮挡 */
.chat-input-bar {
  display: flex; align-items: center; gap: 8rpx;
  padding: 16rpx 20rpx calc(16rpx + env(safe-area-inset-bottom));
  background: var(--card); border-top: 1rpx solid var(--border); box-sizing: border-box;
}
.emoji-btn { color: var(--text-soft); padding: 4rpx; line-height: 1; }
.poke-btn { color: var(--primary); padding: 4rpx; line-height: 1; }
.chat-input {
  flex: 1; box-sizing: border-box; min-height: 72rpx; padding: 14rpx 24rpx;
  background: var(--chip); border-radius: 28rpx; font-size: 30rpx; line-height: 1.5; color: var(--text);
}
.expand-btn { color: var(--text-soft); font-size: 26rpx; padding: 0 10rpx; line-height: 1; white-space: nowrap; }
.send-btn {
  padding: 0 32rpx; height: 72rpx; line-height: 72rpx; border-radius: 36rpx;
  background: var(--primary-soft); color: #fff; font-size: 28rpx;
}
.send-btn.on { background: var(--primary); }

/* 全屏输入 */
.full-input-mask {
  position: fixed; left: 0; top: 0; right: 0; bottom: 0;
  background: var(--bg-1); z-index: 100; display: flex; flex-direction: column;
}
.full-input-topbar {
  height: 96rpx; display: flex; align-items: center; justify-content: space-between;
  padding: 0 24rpx; background: var(--card); border-bottom: 1rpx solid var(--border); box-sizing: border-box;
}
.fi-btn { font-size: 30rpx; color: var(--text-soft); padding: 8rpx 12rpx; }
.fi-btn.ok.on { color: var(--primary); font-weight: 600; }
.fi-title { font-size: 30rpx; color: var(--text); font-weight: 600; }
.full-input-area {
  width: 100%; box-sizing: border-box; padding: 28rpx 32rpx;
  font-size: 32rpx; line-height: 1.6; color: var(--text);
}

/* 消息全屏查看 */
.msg-view-mask {
  position: fixed; left: 0; top: 0; right: 0; bottom: 0;
  background: rgba(0,0,0,.45); z-index: 110;
  display: flex; align-items: center; justify-content: center; padding: 60rpx; box-sizing: border-box;
}
.msg-view-card {
  width: 100%; max-height: 70vh; background: var(--card); border-radius: 24rpx;
  display: flex; flex-direction: column; overflow: hidden; box-shadow: 0 8rpx 40rpx rgba(0,0,0,.2);
}
.msg-view-scroll { max-height: 56vh; padding: 32rpx; box-sizing: border-box; }
.msg-view-text { font-size: 32rpx; line-height: 1.6; color: var(--text); display: block; }
.msg-view-actions { display: flex; border-top: 1rpx solid var(--border); }
.msg-view-btn { flex: 1; text-align: center; padding: 26rpx 0; font-size: 30rpx; color: var(--text-soft); }
.msg-view-btn.primary { color: var(--primary); font-weight: 600; border-left: 1rpx solid var(--border); }

/* 「+」按钮 */
.plus-btn { color: var(--text-soft); padding: 4rpx; line-height: 1; }

/* 媒体消息在气泡行里的对齐：和文本气泡同样的 order */
.bubble-row .media-img { order: 3; }
.bubble-row.me .media-img { order: 2; }
.bubble-row .file-bubble { order: 3; }
.bubble-row.me .file-bubble { order: 2; }

/* 图片气泡 */
.bubble-img { max-width: 320rpx; border-radius: 16rpx; background: var(--chip); }
/* 表情包：无气泡框、小图 */
.bubble-row.is-sticker .media-img { background: transparent; }
.sticker-img { width: 120rpx; border-radius: 8rpx; }

/* 文件卡片 */
.file-bubble { display: flex; align-items: center; gap: 16rpx; max-width: 60%; padding: 18rpx 24rpx; }
.file-ext {
  width: 72rpx; height: 72rpx; border-radius: 14rpx; flex-shrink: 0;
  background: linear-gradient(135deg, var(--primary), var(--primary-deep)); color: #fff;
  display: flex; align-items: center; justify-content: center; font-size: 22rpx; font-weight: 700;
}
.file-info { min-width: 0; }
.file-name { display: block; font-size: 28rpx; color: var(--text); word-break: break-all; line-height: 1.3; }
.file-size { margin-top: 6rpx; display: block; }

/* 表情 / 表情包 面板 */
.chat-panel { background: var(--card); border-top: 1rpx solid var(--border); box-sizing: border-box; }
.panel-scroll { height: 340rpx; box-sizing: border-box; padding: 8rpx 16rpx; }
.emoji-grid { display: grid; grid-template-columns: repeat(8, 1fr); gap: 8rpx; }
.sticker-grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 16rpx; padding: 8rpx; }
.sticker-thumb { width: 100%; height: 140rpx; background: var(--chip); border-radius: 12rpx; }
.sticker-thumb:active { opacity: 0.7; }
.sticker-empty { text-align: center; padding: 60rpx 24rpx; font-size: 26rpx; line-height: 1.6; }
