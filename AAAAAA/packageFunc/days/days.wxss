.days-page { padding-bottom: calc(160rpx + env(safe-area-inset-bottom)); }

/* hero */
.days-hero { text-align: center; padding: 28rpx 32rpx; margin-bottom: 8rpx; }
.days-big { display: flex; align-items: baseline; justify-content: center; gap: 10rpx; }
.big-num { font-size: 96rpx; font-weight: 800; color: var(--primary-deep); line-height: 1; }
.unit { font-size: 30rpx; color: var(--text-soft); }
.days-since { margin-top: 10rpx; }
.start-row { display: flex; align-items: center; justify-content: center; gap: 16rpx; margin-top: 20rpx; }
.start-pick {
  height: 64rpx; line-height: 64rpx; padding: 0 28rpx; background: var(--chip); border-radius: 32rpx;
  font-size: 26rpx; color: var(--text);
}
.start-save { height: 64rpx; line-height: 64rpx; padding: 0 28rpx; background: var(--primary); color: #fff; border-radius: 32rpx; font-size: 26rpx; transition: transform .12s ease; }
.start-save:active { transform: scale(.95); opacity: .9; }

/* event cards */
.event-list { display: flex; flex-direction: column; gap: 16rpx; }
.event-card { display: flex; align-items: flex-start; gap: 18rpx; padding: 24rpx 26rpx; }
.event-card.past { opacity: 0.62; }
.ev-icon {
  width: 72rpx; height: 72rpx; border-radius: 18rpx; flex-shrink: 0;
  background: var(--chip); color: var(--primary); display: flex; align-items: center; justify-content: center;
}
.ev-count { width: 96rpx; text-align: center; color: var(--primary-deep); flex-shrink: 0; padding-top: 4rpx; }
.count-num { font-size: 48rpx; font-weight: 800; line-height: 1; display: block; }
.count-text { font-size: 20rpx; color: var(--text-soft); display: block; margin-top: 6rpx; }
.ev-body { flex: 1; min-width: 0; }
.ev-title-row { display: flex; align-items: center; gap: 10rpx; }
.ev-title { font-size: 30rpx; color: var(--text); font-weight: 600; }
.ev-badge { font-size: 20rpx; color: var(--primary-deep); background: var(--chip); padding: 2rpx 12rpx; border-radius: 10rpx; }
.ev-meta { margin-top: 6rpx; }
.ev-note { margin-top: 10rpx; font-size: 26rpx; color: var(--text); line-height: 1.5; }
.ev-photo { width: 100%; height: 200rpx; border-radius: 16rpx; margin-top: 14rpx; }
.ev-del { color: var(--text-soft); padding: 8rpx; }
.empty { text-align: center; padding: 60rpx 0; font-size: 26rpx; }

/* 悬浮添加 */
.fab {
  position: fixed; right: 40rpx; bottom: calc(56rpx + env(safe-area-inset-bottom));
  width: 104rpx; height: 104rpx; border-radius: 50%; background: var(--primary); color: #fff;
  display: flex; align-items: center; justify-content: center; box-shadow: 0 10rpx 30rpx var(--card-shadow); z-index: 50;
  transition: transform .14s ease;
}
.fab:active { transform: scale(.9); }

/* 添加半屏弹层 */
.add-sheet {
  position: fixed; left: 0; right: 0; bottom: 0; z-index: 201; background: var(--card);
  border-radius: 28rpx 28rpx 0 0; padding: 16rpx 32rpx calc(36rpx + env(safe-area-inset-bottom));
  transform: translateY(110%); transition: transform .26s cubic-bezier(.2,.8,.2,1); box-shadow: 0 -8rpx 32rpx var(--card-shadow);
  max-height: 86vh; overflow-y: auto;
}
.add-sheet.show { transform: translateY(0); }
.sheet-handle { width: 64rpx; height: 8rpx; border-radius: 4rpx; background: var(--border); margin: 0 auto 14rpx; }
.add-title { font-size: 32rpx; font-weight: 700; color: var(--text); margin-bottom: 18rpx; }
.add-input {
  width: 100%; box-sizing: border-box; height: 84rpx; line-height: 84rpx;
  padding: 0 24rpx; background: var(--chip); border-radius: 16rpx; font-size: 28rpx; color: var(--text); margin-bottom: 14rpx;
}
.add-input.picker-row.ph { color: var(--text-soft); }
.add-label { font-size: 24rpx; color: var(--text-soft); margin: 14rpx 0 10rpx; }
.chip-row { display: flex; flex-wrap: wrap; gap: 12rpx; }
.chip {
  display: flex; align-items: center; gap: 6rpx; padding: 12rpx 22rpx; border-radius: 30rpx;
  background: var(--chip); color: var(--text-soft); font-size: 26rpx; border: 2rpx solid transparent;
  transition: transform .12s ease, border-color .14s ease;
}
.chip:active { transform: scale(.95); }
.chip.sel { background: var(--chip); color: var(--primary-deep); border-color: var(--primary); font-weight: 600; }
.photo-row { display: flex; }
.photo-pick {
  width: 140rpx; height: 140rpx; border-radius: 16rpx; background: var(--chip); color: var(--text-soft);
  display: flex; align-items: center; justify-content: center; position: relative; overflow: hidden;
}
.photo-pick.has { background: var(--card); }
.ph-img { width: 100%; height: 100%; }
.ph-clear { position: absolute; top: 6rpx; right: 6rpx; width: 36rpx; height: 36rpx; border-radius: 50%; background: rgba(0,0,0,.5); color: #fff; display: flex; align-items: center; justify-content: center; }
.add-actions { display: flex; gap: 20rpx; margin-top: 26rpx; }
.add-cancel { flex: 1; text-align: center; padding: 22rpx 0; border-radius: 36rpx; background: var(--chip); color: var(--text-soft); font-size: 28rpx; transition: transform .12s ease; }
.add-cancel:active { transform: scale(.97); }
.add-ok { flex: 1; text-align: center; padding: 22rpx 0; border-radius: 36rpx; background: var(--primary); color: #fff; font-size: 28rpx; transition: transform .12s ease; }
.add-ok:active { transform: scale(.97); }
.add-ok.disabled { opacity: 0.6; }
