.wish-page { padding-bottom: calc(220rpx + env(safe-area-inset-bottom)); }

/* 进度 */
.prog-card { padding: 24rpx 28rpx; margin-bottom: 16rpx; }
.prog-row { display: flex; align-items: baseline; justify-content: space-between; }
.prog-title { font-size: 28rpx; font-weight: 600; color: var(--text); }
.prog-num { font-size: 30rpx; font-weight: 700; color: var(--primary-deep); }
.prog-bar { height: 14rpx; border-radius: 8rpx; background: var(--chip); margin-top: 16rpx; overflow: hidden; }
.prog-fill { height: 100%; background: linear-gradient(90deg, var(--primary), var(--primary-deep)); transition: width .3s; }

/* 分类 tab */
.cat-tabs { white-space: nowrap; margin: 0 -32rpx 20rpx; padding: 0 32rpx; }
.cat-tab {
  display: inline-block; padding: 12rpx 28rpx; margin-right: 14rpx; border-radius: 30rpx;
  background: var(--card); color: var(--text-soft); font-size: 26rpx; box-shadow: 0 4rpx 16rpx var(--card-shadow);
}
.cat-tab.sel { background: var(--primary); color: #fff; font-weight: 600; }

/* 心愿卡 */
.wish-list { display: flex; flex-direction: column; gap: 16rpx; }
.wish-item { display: flex; align-items: flex-start; gap: 16rpx; padding: 24rpx 26rpx; }
.wish-cat { width: 60rpx; height: 60rpx; border-radius: 16rpx; background: var(--chip); color: var(--primary); display: flex; align-items: center; justify-content: center; flex-shrink: 0; }
.wish-main { flex: 1; min-width: 0; }
.wish-text { font-size: 30rpx; color: var(--text); line-height: 1.5; word-break: break-all; }
.wish-item.done .wish-text { color: var(--text-soft); text-decoration: line-through; }
.wish-sub { margin-top: 6rpx; }
.wish-photo { width: 100%; height: 220rpx; border-radius: 14rpx; margin-top: 14rpx; }
.wish-note { margin-top: 10rpx; font-size: 26rpx; color: var(--text); line-height: 1.5; }
.wish-done-row { display: flex; align-items: center; justify-content: space-between; margin-top: 12rpx; }
.wish-by { font-size: 24rpx; color: var(--primary-deep); }
.wish-reopen { font-size: 24rpx; color: var(--text-soft); padding: 4rpx 12rpx; background: var(--chip); border-radius: 20rpx; }
.wish-check {
  width: 56rpx; height: 56rpx; border-radius: 50%; border: 3rpx solid var(--border);
  display: flex; align-items: center; justify-content: center; color: var(--text-soft); flex-shrink: 0;
}
.wish-check:active { background: var(--chip); color: var(--primary); }
.wish-del { color: var(--text-soft); padding: 10rpx 4rpx; }
.empty { text-align: center; padding: 70rpx 0; font-size: 26rpx; }

/* 底部添加栏 */
.wish-add { position: fixed; left: 24rpx; right: 24rpx; bottom: calc(28rpx + env(safe-area-inset-bottom)); padding: 18rpx 20rpx; z-index: 40; }
.wish-input { width: 100%; box-sizing: border-box; height: 76rpx; line-height: 76rpx; padding: 0 24rpx; background: var(--chip); border-radius: 38rpx; font-size: 28rpx; color: var(--text); }
.add-cats { display: flex; gap: 12rpx; margin-top: 14rpx; }
.add-cat { display: flex; align-items: center; gap: 6rpx; padding: 8rpx 18rpx; border-radius: 24rpx; background: var(--chip); color: var(--text-soft); font-size: 24rpx; }
.add-cat.sel { background: var(--primary); color: #fff; }
.add-fab {
  position: fixed; right: 36rpx; bottom: calc(150rpx + env(safe-area-inset-bottom));
  width: 88rpx; height: 88rpx; border-radius: 50%; background: var(--primary-deep); color: #fff;
  display: flex; align-items: center; justify-content: center; box-shadow: 0 8rpx 24rpx var(--card-shadow); z-index: 41;
}

/* 完成打卡 */
.fin-photo { display: flex; justify-content: center; margin-bottom: 18rpx; }
.fin-img { width: 200rpx; height: 200rpx; border-radius: 16rpx; }
.fin-ph { width: 200rpx; height: 200rpx; border-radius: 16rpx; background: var(--chip); color: var(--text-soft); display: flex; align-items: center; justify-content: center; }
